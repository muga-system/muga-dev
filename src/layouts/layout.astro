---
// Importar estilos globales
import "../styles/global.css";
import Footer from "../components/ui/Footer/Footer.astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { readFileSync } from "node:fs";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "MUGA - Arquitectura Web para Conversión",
  description = "Conversión, jerarquía, flujo y secuencia aplicados a la estructura de tu web.",
} = Astro.props;
let currentBuildId = "";

try {
  currentBuildId = readFileSync(
    new URL("../../public/build-id.txt", import.meta.url),
    "utf8",
  ).trim();
} catch {
  currentBuildId = "";
}
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/logo/logo.png" />
    <link rel="preconnect" href="https://tracker.metricool.com" crossorigin />
    <script is:inline define:vars={{ currentBuildId }}>
      (() => {
        const storageKey = "muga_build_id";
        const queryParamKey = "__v";
        const htmlBuildId = String(currentBuildId || "");

        const forceReloadWithVersion = (buildId) => {
          const url = new URL(window.location.href);
          url.searchParams.set(queryParamKey, buildId);
          url.searchParams.set("__ts", String(Date.now()));
          window.location.replace(url.toString());
        };

        fetch(`/build-id.txt?t=${Date.now()}`, { cache: "no-store" })
          .then((response) => (response.ok ? response.text() : ""))
          .then((value) => {
            const latestBuildId = value.trim();
            if (!latestBuildId) return;

            const currentUrl = new URL(window.location.href);
            const versionInUrl = currentUrl.searchParams.get(queryParamKey);
            const savedBuildId = window.localStorage.getItem(storageKey);

            if (htmlBuildId && latestBuildId !== htmlBuildId) {
              window.localStorage.setItem(storageKey, latestBuildId);

              if (versionInUrl !== latestBuildId) {
                forceReloadWithVersion(latestBuildId);
              }

              return;
            }

            if (!savedBuildId) {
              window.localStorage.setItem(storageKey, latestBuildId);
              return;
            }

            if (savedBuildId !== latestBuildId) {
              window.localStorage.setItem(storageKey, latestBuildId);

              if (versionInUrl !== latestBuildId) {
                forceReloadWithVersion(latestBuildId);
              }

              return;
            }

            if (versionInUrl && versionInUrl === latestBuildId) {
              currentUrl.searchParams.delete(queryParamKey);
              currentUrl.searchParams.delete("__ts");
              window.history.replaceState({}, "", currentUrl.toString());
            }
          })
          .catch(() => {});
      })();
    </script>
    <script is:inline>
      function loadScript(a) {
        var b = document.getElementsByTagName("head")[0],
          c = document.createElement("script");
        c.type = "text/javascript";
        c.src = "https://tracker.metricool.com/resources/be.js";
        c.async = true;
        c.onreadystatechange = a;
        c.onload = a;
        b.appendChild(c);
      }
      loadScript(function () {
        beTracker.t({ hash: "80c73763fb5e472734cbe390b7b2b5c6" });
      });
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <main id="main-content">
      <slot />
    </main>
    <script src="../scripts/analytics.ts" defer></script>
    <Footer />
    <SpeedInsights />
  </body>
</html>
