---
// Importar estilos globales
import "../styles/global.css";
import Footer from "../components/ui/Footer/Footer.astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { readFileSync } from "node:fs";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "MUGA - Arquitectura Web para Conversión",
  description = "Conversión, jerarquía, flujo y secuencia aplicados a la estructura de tu web.",
} = Astro.props;
let currentBuildId = "";

try {
  currentBuildId = readFileSync(
    new URL("../../public/build-id.txt", import.meta.url),
    "utf8",
  ).trim();
} catch {
  currentBuildId = "";
}
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/logo/logo.png" />
    <link rel="preconnect" href="https://tracker.metricool.com" crossorigin />
    <script is:inline define:vars={{ currentBuildId }}>
      (() => {
        const storageKey = "muga_build_id";
        const queryParamKey = "__v";
        const htmlBuildId = String(currentBuildId || "");

        const forceReloadWithVersion = (buildId) => {
          const url = new URL(window.location.href);
          url.searchParams.set(queryParamKey, buildId);
          url.searchParams.set("__ts", String(Date.now()));
          window.location.replace(url.toString());
        };

        fetch(`/build-id.txt?t=${Date.now()}`, { cache: "no-store" })
          .then((response) => (response.ok ? response.text() : ""))
          .then((value) => {
            const latestBuildId = value.trim();
            if (!latestBuildId) return;

            const currentUrl = new URL(window.location.href);
            const versionInUrl = currentUrl.searchParams.get(queryParamKey);
            const savedBuildId = window.localStorage.getItem(storageKey);

            if (htmlBuildId && latestBuildId !== htmlBuildId) {
              window.localStorage.setItem(storageKey, latestBuildId);

              if (versionInUrl !== latestBuildId) {
                forceReloadWithVersion(latestBuildId);
              }

              return;
            }

            if (!savedBuildId) {
              window.localStorage.setItem(storageKey, latestBuildId);
              return;
            }

            if (savedBuildId !== latestBuildId) {
              window.localStorage.setItem(storageKey, latestBuildId);

              if (versionInUrl !== latestBuildId) {
                forceReloadWithVersion(latestBuildId);
              }

              return;
            }

            if (versionInUrl && versionInUrl === latestBuildId) {
              currentUrl.searchParams.delete(queryParamKey);
              currentUrl.searchParams.delete("__ts");
              window.history.replaceState({}, "", currentUrl.toString());
            }
          })
          .catch(() => {});
      })();
    </script>
    <script is:inline>
      (() => {
        const ANALYTICS_CONSENT_KEY = "muga_analytics_consent";
        let metricoolLoaded = false;

        const hasAnalyticsConsent = () => {
          try {
            return window.localStorage.getItem(ANALYTICS_CONSENT_KEY) === "granted";
          } catch {
            return false;
          }
        };

        const loadMetricool = () => {
          if (metricoolLoaded || !hasAnalyticsConsent()) return;
          metricoolLoaded = true;

          const head = document.getElementsByTagName("head")[0];
          const script = document.createElement("script");
          script.type = "text/javascript";
          script.src = "https://tracker.metricool.com/resources/be.js";
          script.async = true;
          script.onload = () => {
            if (typeof window.beTracker !== "undefined") {
              window.beTracker.t({ hash: "80c73763fb5e472734cbe390b7b2b5c6" });
            }
          };
          head.appendChild(script);
        };

        if (hasAnalyticsConsent()) loadMetricool();
        window.addEventListener("muga:analytics-consent-granted", loadMetricool);
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <main id="main-content">
      <slot />
    </main>
    <div
      data-cookie-banner
      class="fixed inset-x-4 bottom-4 z-[70] mx-auto hidden w-auto max-w-xl border border-white/15 bg-obscure/85 p-4 text-white shadow-2xl shadow-black/45 backdrop-blur-sm"
      role="dialog"
      aria-live="polite"
      aria-label="Preferencias de analitica"
    >
      <p class="text-sm leading-6 text-graylight">
        Usamos analitica para entender visitas y mejorar el sitio. No afecta la funcionalidad principal.
      </p>
      <div class="mt-3 flex flex-wrap items-center justify-end gap-2">
        <button
          type="button"
          data-cookie-reject
          class="inline-flex items-center justify-center border border-white/20 px-3 py-2 text-xs font-semibold text-white hover:border-white/40"
        >
          Rechazar
        </button>
        <button
          type="button"
          data-cookie-accept
          class="inline-flex items-center justify-center border border-accent/70 bg-accent px-3 py-2 text-xs font-semibold text-obscure hover:bg-accent/90"
        >
          Aceptar
        </button>
      </div>
    </div>
    <script is:inline>
      (() => {
        const ANALYTICS_CONSENT_KEY = "muga_analytics_consent";
        const banner = document.querySelector("[data-cookie-banner]");
        const acceptButton = document.querySelector("[data-cookie-accept]");
        const rejectButton = document.querySelector("[data-cookie-reject]");

        const readConsent = () => {
          try {
            return window.localStorage.getItem(ANALYTICS_CONSENT_KEY);
          } catch {
            return null;
          }
        };

        const writeConsent = (value) => {
          try {
            window.localStorage.setItem(ANALYTICS_CONSENT_KEY, value);
          } catch {
            // Ignore storage errors.
          }
        };

        const applyConsent = (value) => {
          writeConsent(value);
          if (banner) banner.classList.add("hidden");

          if (value === "granted") {
            window.dispatchEvent(new CustomEvent("muga:analytics-consent-granted"));
          }
        };

        const openConsentBanner = () => {
          banner?.classList.remove("hidden");
        };

        const existingConsent = readConsent();
        if (!existingConsent) {
          openConsentBanner();
        }

        acceptButton?.addEventListener("click", () => applyConsent("granted"));
        rejectButton?.addEventListener("click", () => applyConsent("denied"));

        document.addEventListener("click", (event) => {
          const target = event.target as Element | null;
          const trigger = target?.closest("[data-open-consent-preferences]");
          if (!trigger) return;
          openConsentBanner();
        });

        window.addEventListener("muga:open-analytics-consent", openConsentBanner as EventListener);
      })();
    </script>
    <script>
      import "../scripts/analytics.ts";
    </script>
    <Footer />
    <SpeedInsights />
  </body>
</html>
