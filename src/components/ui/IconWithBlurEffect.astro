---
interface Props {
  iconPath: string;
  iconAlt: string;
  iconSize?: string;
  blurAmount?: string;
  iconKey?: string;
}

const { 
  iconPath, 
  iconAlt, 
  iconSize = "w-40 h-40", 
  blurAmount = "3px",
  iconKey
} = Astro.props;
---

<div class="icon-container absolute inset-0 flex items-center justify-center pointer-events-none z-0">
  <img
    src={iconPath}
    class={`icon-with-blur-effect ${iconSize}`}
    alt={iconAlt}
    loading="lazy"
    decoding="async"
    data-icon-key={iconKey}
    style={`--blur-amount: ${blurAmount};`}
  />
</div>

<style>
  .icon-with-blur-effect {
    stroke: #ff5353;
    stroke-width: 1;
    opacity: 0;
    filter: blur(var(--blur-amount, 3px));
    transition: filter 0.3s ease;
  }
</style>

<script>
  type MugaIconWindow = Window &
    typeof globalThis & {
      __mugaSetupIconEffects?: () => void;
      __mugaIconEffectsBound?: boolean;
    };

  const mugaWindow = window as MugaIconWindow;

  if (!mugaWindow.__mugaSetupIconEffects) {
    mugaWindow.__mugaSetupIconEffects = () => {
      const icons = document.querySelectorAll<HTMLImageElement>(".icon-with-blur-effect");

      icons.forEach(function (icon) {
        if (icon.dataset.bound === "true") return;

        const bentoCell = icon.closest<HTMLElement>(".bento-cell");
        if (!bentoCell) return;

        let iconRect = icon.getBoundingClientRect();
        let pointerX = 0;
        let pointerY = 0;
        let rafId: number | null = null;

        const updateIconRect = () => {
          iconRect = icon.getBoundingClientRect();
        };

        const renderMask = () => {
          rafId = null;
          icon.style.opacity = "1";
          const maskImage = `radial-gradient(circle 50px at ${pointerX}px ${pointerY}px, black 0%, rgba(0,0,0,0.8) 40%, rgba(0,0,0,0.5) 60%, rgba(0,0,0,0.2) 80%, transparent 100%)`;
          icon.style.setProperty("-webkit-mask-image", maskImage);
          icon.style.maskImage = maskImage;
        };

        icon.style.opacity = "0";

        const updateMask = (event: MouseEvent) => {
          pointerX = event.clientX - iconRect.left;
          pointerY = event.clientY - iconRect.top;

          if (rafId === null) {
            rafId = requestAnimationFrame(renderMask);
          }
        };

        bentoCell.addEventListener("mouseenter", updateIconRect, { passive: true });
        bentoCell.addEventListener("mousemove", updateMask);
        window.addEventListener("resize", updateIconRect, { passive: true });
        window.addEventListener("scroll", updateIconRect, { passive: true });

        bentoCell.addEventListener("mouseleave", function () {
          if (rafId !== null) {
            cancelAnimationFrame(rafId);
            rafId = null;
          }
          icon.style.opacity = "0";
        });

        icon.dataset.bound = "true";
      });
    };
  }

  if (!mugaWindow.__mugaIconEffectsBound && mugaWindow.__mugaSetupIconEffects) {
    document.addEventListener("astro:page-load", mugaWindow.__mugaSetupIconEffects);
    document.addEventListener("DOMContentLoaded", mugaWindow.__mugaSetupIconEffects);
    mugaWindow.__mugaIconEffectsBound = true;
  }

  mugaWindow.__mugaSetupIconEffects?.();
</script>
