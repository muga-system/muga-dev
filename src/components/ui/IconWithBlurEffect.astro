---
interface Props {
  iconPath: string;
  iconAlt: string;
  iconSize?: string;
  blurAmount?: string;
  iconKey?: string;
}

const { 
  iconPath, 
  iconAlt, 
  iconSize = "w-40 h-40", 
  blurAmount = "3px",
  iconKey
} = Astro.props;
---

<div class="icon-container absolute inset-0 flex items-center justify-center pointer-events-none z-0">
  <img
    src={iconPath}
    class={`icon-with-blur-effect ${iconSize}`}
    alt={iconAlt}
    data-icon-key={iconKey}
    style={`--blur-amount: ${blurAmount};`}
  />
</div>

<style>
  .icon-with-blur-effect {
    stroke: #ff5353;
    stroke-width: 1;
    opacity: 0;
    filter: blur(var(--blur-amount, 3px));
    transition: filter 0.3s ease;
  }
</style>

<script>
  if (!window.__mugaSetupIconEffects) {
    window.__mugaSetupIconEffects = () => {
      const icons = document.querySelectorAll(".icon-with-blur-effect");

      icons.forEach(function (icon) {
        if (icon.dataset.bound === "true") return;

        const bentoCell = icon.closest(".bento-cell");
        if (!bentoCell) return;

        icon.style.opacity = "0";

        function updateMask(e) {
          const svgRect = icon.getBoundingClientRect();

          const svgX = e.clientX - svgRect.left;
          const svgY = e.clientY - svgRect.top;

          icon.style.opacity = "1";
          const maskImage = `radial-gradient(circle 50px at ${svgX}px ${svgY}px, black 0%, rgba(0,0,0,0.8) 40%, rgba(0,0,0,0.5) 60%, rgba(0,0,0,0.2) 80%, transparent 100%)`;
          icon.style.webkitMaskImage = maskImage;
          icon.style.maskImage = maskImage;
        }

        bentoCell.addEventListener("mousemove", updateMask);

        bentoCell.addEventListener("mouseleave", function () {
          icon.style.opacity = "0";
        });

        icon.dataset.bound = "true";
      });
    };
  }

  if (!window.__mugaIconEffectsBound) {
    document.addEventListener("astro:page-load", window.__mugaSetupIconEffects);
    document.addEventListener("DOMContentLoaded", window.__mugaSetupIconEffects);
    window.__mugaIconEffectsBound = true;
  }

  window.__mugaSetupIconEffects();
</script>
