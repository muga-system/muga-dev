---
export interface Props {}

const year = new Date().getFullYear();

const primaryLinks = [
  { href: "/formatos", label: "Formatos" },
  { href: "/criterios", label: "Criterios" },
  { href: "/casos", label: "Referencias" },
  { href: "/modelo", label: "Modelo" },
  { href: "/contacto", label: "Contacto" },
];
---

<footer class="mt-20 border-t border-white/10 bg-obscure">
  <div class="page-container py-14">
    <div class="flex flex-col gap-8 border-b border-white/10 pb-10 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="muga-badge muga-badge--sm">MUGA DEV</p>
        <h2 class="mt-3 max-w-xl text-xl font-semibold leading-tight text-white sm:text-2xl">
          Arquitectura clara desde el inicio.
        </h2>
        <p class="mt-3 max-w-xl text-sm text-graylight">
          Estructura, jerarquía y recorrido claro para sostener una acción principal.
        </p>
      </div>
      <a
        href="/contacto"
        class="inline-flex w-fit items-center gap-2 border border-accent px-4 py-2 text-sm font-semibold text-accent transition-colors hover:bg-accent hover:text-obscure focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-obscure"
        data-analytics-event="footer_cta_click"
        data-analytics-label="contanos_tu_caso"
        data-analytics-location="footer"
        data-analytics-destination="/contacto"
      >
        Contanos tu caso
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <nav aria-label="Enlaces del sitio" class="py-8">
      <ul class="flex flex-wrap items-center gap-x-6 gap-y-3">
        {primaryLinks.map((link) => (
          <li>
            <a href={link.href} class="inline-flex min-h-10 items-center py-1 text-sm text-graylight transition-colors hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-obscure" data-analytics-event="footer_link_click" data-analytics-label={link.label.toLowerCase()} data-analytics-location="footer" data-analytics-destination={link.href}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="flex flex-col gap-3 border-t border-white/10 pt-6 text-xs text-graylight sm:flex-row sm:items-center sm:justify-between">
      <p>
        <span class="font-mono">{year}</span>
        <span class="ml-1 font-semibold text-accent">MUGA</span> - Arquitectura web como sistema.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://muga.studio" class="inline-flex min-h-10 items-center transition-colors hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-obscure" data-analytics-event="footer_link_click" data-analytics-label="muga_studio" data-analytics-location="footer" data-analytics-destination="https://muga.studio">MUGA Studio</a>
        <span class="hidden h-3 w-px bg-white/20 sm:inline-block"></span>
        <p class="font-mono">Versión 1.1.1</p>
      </div>
    </div>
  </div>
</footer>
