---
export interface Props {
}

interface NavItem {
  label: string;
  href: string;
}

const navItems: NavItem[] = [
  { label: "Formatos", href: "/formatos" },
  { label: "Criterios", href: "/criterios" },
  { label: "Nosotros", href: "/nosotros" },
  { label: "Contacto", href: "/contacto" },
];

const casesItem: NavItem = {
  label: "Casos",
  href: "/casos"
};

const currentPath = Astro.url.pathname;

const isActive = (href: string) =>
  href === "/contacto" ? currentPath.startsWith("/contacto") : currentPath === href;
---

<header id="navbar" class="fixed inset-x-0 top-0 z-50 transition-colors duration-300 navbar-scrolled" transition:animate="none">
  <nav aria-label="Global" class="flex items-center justify-between p-6 lg:px-8 h-[72px]">
    <div class="flex items-center space-x-6" transition:animate="none">
      <div class="flex items-center justify-start" transition:animate="none">
        <a href="/" transition:animate="none">
          <span class="sr-only">MUGA</span>
          <img src="/logo/logo.png" alt="" class="h-8 w-8" transition:animate="none" />
        </a>
      </div>
      
      <div class="flex lg:hidden ml-4">
        <slot name="mobile-breadcrumb" />
      </div>
      
      <div class="hidden lg:flex lg:gap-x-2 items-center ml-2" transition:animate="none">
        {navItems.map((item, index) => (
          <a
            href={item.href}
            class={`text-sm font-semibold ${isActive(item.href) ? "text-white" : "text-graylight hover:text-white"} ${index > 0 ? "ml-4" : ""}`}
            transition:animate="none"
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>

    <div class="flex lg:hidden" transition:animate="none">
      <button id="mobile-menu-button" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-200" transition:animate="none">
        <span class="sr-only">Abrir menu principal</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-6" aria-hidden="true" transition:animate="none">
          <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <div class="hidden lg:flex lg:flex-1 lg:justify-end" transition:animate="none">
      <a href={casesItem.href} class={`text-sm font-semibold ${isActive(casesItem.href) ? 'text-white' : 'text-graylight hover:text-white'} flex items-center`} transition:animate="none">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" transition:animate="none">
          <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
          <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
        </svg>
        {casesItem.label} <span aria-hidden="true" class="ml-1" transition:animate="none">&rarr;</span>
      </a>
    </div>
  </nav>

  <div id="mobile-menu" class="fixed inset-0 z-50 hidden lg:hidden bg-obscure">
    <div class="fixed inset-y-0 right-0 w-full sm:max-w-sm overflow-y-auto bg-obscure sm:ring-1 sm:ring-gray-100/10">
      <div class="flex items-center justify-between h-[72px] px-6">
        <a href="/" class="flex items-center">
          <span class="sr-only">MUGA</span>
          <img src="/logo/logo.png" alt="" class="h-8 w-8" />
        </a>
        <button id="close-mobile-menu" class="-m-2.5 rounded-md p-2.5 text-gray-200">
          <span class="sr-only">Cerrar menu</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-6" aria-hidden="true">
            <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <div class="mt-6 px-6 pb-6 flow-root">
        <div class="-my-6 divide-y divide-white/10">
          <div class="space-y-2 py-6">
            {navItems.map((item) => (
              <a href={item.href} class="block rounded-lg px-3 py-2 text-base font-semibold text-white hover:bg-white/5">
                {item.label}
              </a>
            ))}
          </div>
          <div class="py-6">
            <a href={casesItem.href} class="flex items-center rounded-lg px-3 py-2.5 text-base font-semibold text-white hover:bg-white/5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
              </svg>
              {casesItem.label}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  :global(body) {
    padding-top: 112px;
  }

  .navbar-scrolled {
    background-color: #191717; 
    box-shadow: 0 4px 6px -1px #191717, 0 2px 4px -1px #191717;
  }
</style>

<script is:inline define:vars={{ currentPath }}>
  const initNavbarBehavior = () => {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const closeMenuButton = document.getElementById('close-mobile-menu');
    const mobileMenu = document.getElementById('mobile-menu');

    const handleScroll = () => {
      const breadcrumb = document.getElementById('breadcrumb');
      if (breadcrumb) {
        if (window.scrollY > 0) {
          breadcrumb.classList.add('scrolled');
        } else {
          breadcrumb.classList.remove('scrolled');
        }
      }
    };

    handleScroll();

    window.addEventListener('scroll', handleScroll);

    mobileMenuButton?.addEventListener('click', () => {
      mobileMenu?.classList.remove('hidden');
    });

    closeMenuButton?.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });

    const mobileLinks = mobileMenu?.querySelectorAll('a');
    mobileLinks?.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
      });
    });
  };

  document.addEventListener('astro:page-load', initNavbarBehavior);

  document.addEventListener('DOMContentLoaded', initNavbarBehavior);
</script>
