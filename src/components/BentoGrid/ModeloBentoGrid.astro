---
import BentoCell from "../ui/BentoCell.astro";
import IconWithBlurEffect from "../ui/IconWithBlurEffect.astro";
import ArrowLink from "../ui/Button/ArrowLink.astro";
---

<section class="relative px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div
      class="grid grid-cols-1 md:grid-cols-4 gap-0 auto-rows-[minmax(200px,auto)]"
    >
      <BentoCell
        title="Base técnica"
        colSpan="col-span-1 md:col-span-1"
        bgClass="bg-transparent"
        borderClass="border-white/5"
        rounded={false}
        lightEffect={true}
      >
        <IconWithBlurEffect
          iconPath="/icons/layers.svg"
          iconAlt="Icono de base tecnica"
          iconKey="base"
        />

        <ul class="space-y-2 text-muga-neutral relative z-10">
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>
              <strong class="text-graylight">Astro:</strong> base de arquitectura
              estática optimizada para rendimiento y control.
            </span>
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>
              <strong class="text-graylight">TailwindCSS:</strong> sistema de estilos
              consistente y escalable.
            </span>
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>
              <strong class="text-graylight">TypeScript:</strong> seguridad, mantenibilidad
              y control del código.
            </span>
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>
              <strong class="text-graylight">Hostinger:</strong> infraestructura confiable
              para despliegue y operación.
            </span>
          </li>
        </ul>
      </BentoCell>

      <BentoCell
        title="Encaje"
        colSpan="col-span-1 md:col-span-1"
        bgClass="bg-transparent"
        borderClass="border-white/5"
        rounded={false}
        lightEffect={true}
      >
        <IconWithBlurEffect
          iconPath="/icons/shield-user.svg"
          iconAlt="Icono de encaje"
          iconKey="encaje"
        />

        <ul class="space-y-2 text-muga-neutral relative z-10">
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span
              >Equipos que necesitan salir rapido sin desordenar la base
              tecnica.</span
            >
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span
              >Negocios que necesitan una base clara para vender y sostener el
              sitio.</span
            >
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span
              >Equipos que trabajan sobre Astro y necesitan soporte
              estructural.</span
            >
          </li>
        </ul>
      </BentoCell>

      <BentoCell
        title="Sistema"
        colSpan="col-span-1 md:col-span-2"
        bgClass="bg-transparent"
        borderClass="border-white/5"
        rounded={false}
        lightEffect={true}
      >
        <IconWithBlurEffect
          iconPath="/icons/drafting-compass.svg"
          iconAlt="Icono de sistema"
          iconKey="sistema"
        />

        <div class="relative z-10">
          <p class="text-muga-neutral">
            Cada proyecto parte de una base tecnica comun: <strong
              >MUGA Base System</strong
            >. Eso permite trabajar con reglas claras, decisiones repetibles y
            metricas objetivas desde el inicio.
          </p>
          <p class="mt-4 text-muga-neutral">
            No improvisamos estructuras ni resolvemos el mismo problema dos
            veces. Construimos sistemas modulares para mantener control,
            continuidad y rendimiento estable.
          </p>
        </div>
      </BentoCell>

      <BentoCell
        title="Checklist"
        colSpan="col-span-1 md:col-span-1"
        bgClass="bg-transparent"
        borderClass="border-white/5"
        rounded={false}
        lightEffect={true}
      >
        <IconWithBlurEffect
          iconPath="/icons/list-checks.svg"
          iconAlt="Icono de checklist"
          iconKey="checklist"
        />

        <ul class="space-y-2 text-muga-neutral relative z-10">
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>Métricas de rendimiento definidas desde el inicio.</span>
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>Accesibilidad auditada como estándar, no como extra.</span>
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>Informe final con resultados medibles.</span>
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>Entorno de despliegue configurado y validado.</span>
          </li>
        </ul>
      </BentoCell>

      <BentoCell
        title="Métricas"
        colSpan="col-span-1 md:col-span-2"
        bgClass="bg-transparent"
        borderClass="border-white/5"
        rounded={false}
        lightEffect={true}
      >
        <div class="relative z-10">
          <div class="overflow-x-auto">
            <table class="min-w-[34rem] text-sm">
            <thead>
              <tr class="border-b border-white/10">
                <th class="py-2 text-left text-muga-neutral">Métrica</th>
                <th class="py-2 text-left text-muga-neutral">Descripción</th>
                <th class="py-2 text-left text-muga-neutral">Objetivo</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-white/10">
                <td class="py-2 pr-4 text-muga-neutral">Velocidad (LCP)</td>
                <td class="py-2 pr-4 text-muga-neutral"
                  >Carga del contenido principal</td
                >
                <td class="py-2 font-semibold text-muga-primary">≤ 2.5s</td>
              </tr>
              <tr class="border-b border-white/10">
                <td class="py-2 pr-4 text-muga-neutral">Estabilidad (CLS)</td>
                <td class="py-2 pr-4 text-muga-neutral"
                  >Cambios de layout inesperados</td
                >
                <td class="py-2 font-semibold text-muga-primary">≤ 0.1</td>
              </tr>
              <tr class="border-b border-white/10">
                <td class="py-2 pr-4 text-muga-neutral">Interactividad (INP)</td
                >
                <td class="py-2 pr-4 text-muga-neutral"
                  >Tiempo de respuesta a interacción</td
                >
                <td class="py-2 font-semibold text-muga-primary">≤ 200ms</td>
              </tr>
              <tr class="border-b border-white/10">
                <td class="py-2 pr-4 text-muga-neutral">Accesibilidad</td>
                <td class="py-2 pr-4 text-muga-neutral"
                  >Cumplimiento WCAG / Lighthouse</td
                >
                <td class="py-2 font-semibold text-muga-primary">≥ 90/100</td>
              </tr>
              <tr>
                <td class="py-2 pr-4 text-muga-neutral">SEO / Indexación</td>
                <td class="py-2 pr-4 text-muga-neutral"
                  >Cobertura de páginas indexadas</td
                >
                <td class="py-2 font-semibold text-muga-primary">≥ 95%</td>
              </tr>
            </tbody>
            </table>
          </div>
        </div>
      </BentoCell>

      <BentoCell
        title="Consecuencia"
        colSpan="col-span-1 md:col-span-1"
        bgClass="bg-transparent"
        borderClass="border-white/5"
        rounded={false}
        lightEffect={true}
      >
        <IconWithBlurEffect
          iconPath="/icons/badge-check.svg"
          iconAlt="Icono de consecuencia"
          iconKey="consecuencia"
        />

        <ul class="space-y-2 text-muga-neutral">
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>Rendimiento predecible y medible</span>
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>Arquitectura preparada para escalar</span>
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>Menor costo de mantenimiento a largo plazo</span>
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>Decisiones técnicas transparentes</span>
          </li>
        </ul>
      </BentoCell>

      <BentoCell
        title="Criterio"
        colSpan="col-span-1 md:col-span-2"
        bgClass="bg-transparent"
        borderClass="border-white/5"
        lightEffect={true}
      >
        <IconWithBlurEffect
          iconPath="/icons/brain-cog.svg"
          iconAlt="Icono de criterio"
          iconKey="criterio"
        />

        <p class="text-muga-neutral">
          Trabajamos con reglas claras, documentacion explicita y metricas
          compartidas. Eso reduce friccion, evita desvio y permite decidir con
          informacion real.
        </p>
        <p class="mt-4 text-muga-neutral">
          Preferimos frenar un alcance mal definido antes que comprometer la
          estabilidad del sistema.
        </p>
      </BentoCell>

      <BentoCell
        title="Extensiones"
        colSpan="col-span-1 md:col-span-1"
        bgClass="bg-transparent"
        borderClass="border-white/5"
        rounded={false}
        lightEffect={true}
      >
        <IconWithBlurEffect
          iconPath="/icons/package-plus.svg"
          iconAlt="Icono de extensiones"
          iconKey="extensiones"
        />

        <ul class="space-y-2 text-muga-neutral relative z-10">
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span
              >React para interactividad puntual cuando el sistema lo requiere</span
            >
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>Strapi como CMS headless desacoplado</span>
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>Supabase como backend y base de datos</span>
          </li>
          <li class="flex items-start">
            <span class="text-muga-primary mr-2">•</span>
            <span>Cloudflare para distribución y performance global</span>
          </li>
        </ul>
      </BentoCell>

      <BentoCell
        title="Contacto"
        colSpan="col-span-1 md:col-span-1"
        bgClass="bg-transparent"
        borderClass="border-white/5"
        rounded={false}
        lightEffect={true}
      >
        <IconWithBlurEffect
          iconPath="/icons/message-square-text.svg"
          iconAlt="Icono de Contacto"
          iconKey="contacto-modelo"
        />

        <div class="flex flex-col space-y-4 relative z-10">
          <ArrowLink href="/contacto" text="Agendar diagnostico" />
          <ArrowLink href="/casos" text="Ver casos" />
        </div>
      </BentoCell>
    </div>
  </div>
</section>

<script src="../../scripts/bento-grid.ts"></script>
