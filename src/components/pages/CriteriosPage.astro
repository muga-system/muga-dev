---
import Layout from "../../layouts/layout.astro";
import Navigation from "../ui/Navigation/Navigation.astro";
import Breadcrumb from "../ui/Breadcrumb/Breadcrumb.astro";
import PageHeroSection from "../HeroSection/PageHeroSection.astro";
import BentoCell from "../ui/BentoCell.astro";
import IconWithBlurEffect from "../ui/IconWithBlurEffect.astro";
import ArrowLink from "../ui/Button/ArrowLink.astro";
import type { BreadcrumbItem } from "../../types";

const breadcrumbItems: BreadcrumbItem[] = [
  {
    label: "Criterios",
    href: "/criterios",
    active: true,
  },
];
---

<Layout
  title="Criterios tecnicos | MUGA"
  description="Rendimiento, accesibilidad, SEO y estructura como base tecnica."
>
  <Navigation>
    <Breadcrumb slot="mobile-breadcrumb" items={breadcrumbItems} />
  </Navigation>
  <div class="hidden lg:block">
    <Breadcrumb items={breadcrumbItems} />
  </div>
  <PageHeroSection
    title="Criterios tecnicos"
    description="Rendimiento, accesibilidad, SEO y estructura como soporte del objetivo."
    textAlign="left"
    showBadge={true}
    badgeText="Criterios"
  />

  <section class="relative px-6 py-20 lg:px-8 lg:py-24">
    <div class="mx-auto max-w-7xl">
      <div
        class="grid grid-cols-1 gap-4 md:grid-cols-4 md:gap-0 auto-rows-[minmax(200px,auto)]"
      >
        <BentoCell
          title="Base modular"
          colSpan="col-span-1 md:col-span-1"
          bgClass="bg-transparent"
          rounded={false}
          lightEffect={true}
        >
          <IconWithBlurEffect 
            iconPath="/icons/component.svg"
            iconAlt="Icono de componente"
            iconKey="component"
          />

          <ul class="space-y-2 text-muga-neutral relative z-10">
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Componentes reutilizables</span>
            </li>
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Consistencia de sistema</span>
            </li>
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Mantenimiento simplificado</span>
            </li>
          </ul>
        </BentoCell>

        <BentoCell
          title="Rendimiento"
          colSpan="col-span-1 md:col-span-1"
          bgClass="bg-transparent"
          borderClass="border-white/5"
          rounded={false}
          lightEffect={true}
        >
          <IconWithBlurEffect 
            iconPath="/icons/chart-no-axes-combined.svg"
            iconAlt="Icono de rendimiento"
            iconKey="chart"
          />

          <ul class="space-y-2 text-muga-neutral relative z-10">
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Carga rápida</span>
            </li>
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Core Web Vitals optimizados</span>
            </li>
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Lectura sin cortes</span>
            </li>
          </ul>
        </BentoCell>

        <BentoCell
          title="Criterio"
          colSpan="col-span-1 md:col-span-2"
          bgClass="bg-transparent"
          borderClass="border-white/5"
          rounded={false}
          lightEffect={true}
        >
          <IconWithBlurEffect 
            iconPath="/icons/goal.svg"
            iconAlt="Icono de objetivo"
            iconKey="goal"
          />

          <p class="text-muga-neutral relative z-10">
            Definimos una base tecnica clara antes de construir. Eso ordena
            decisiones, reduce desvio y sostiene el objetivo principal.
          </p>
          <p class="mt-4 text-muga-neutral relative z-10">
            Cada proyecto parte de componentes reutilizables para mantener
            consistencia, control y un rendimiento estable en cada ajuste.
          </p>
        </BentoCell>

        <BentoCell
          title="Accesibilidad"
          colSpan="col-span-1 md:col-span-1"
          bgClass="bg-transparent"
          borderClass="border-white/5"
          rounded={false}
          lightEffect={true}
        >
          <IconWithBlurEffect 
            iconPath="/icons/keyboard.svg"
            iconAlt="Icono de teclado"
            iconKey="keyboard"
          />

          <ul class="space-y-2 text-muga-neutral relative z-10">
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Estándares WCAG AA</span>
            </li>
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Navegación por teclado</span>
            </li>
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Contraste adecuado</span>
            </li>
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Textos alternativos</span>
            </li>
          </ul>
        </BentoCell>

        <BentoCell
          title="Base técnica"
          colSpan="col-span-1 md:col-span-2"
          bgClass="bg-transparent"
          borderClass="border-white/5"
          rounded={false}
          lightEffect={true}
        >
          <IconWithBlurEffect 
            iconPath="/icons/cpu.svg"
            iconAlt="Icono de CPU"
            iconKey="cpu"
            iconSize="w-40 h-40 opacity-30"
          />

          <div class="flex flex-wrap gap-2 mb-4 relative z-20">
            <span class="px-2 py-1 bg-accent/10 text-accent text-sm"
              >Astro</span
            >
            <span class="px-2 py-1 bg-accent/10 text-accent text-sm"
              >TailwindCSS</span
            >
            <span class="px-2 py-1 bg-accent/10 text-accent text-sm"
              >TypeScript</span
            >
            <span class="px-2 py-1 bg-accent/10 text-accent text-sm"
              >React</span
            >
            <span class="px-2 py-1 bg-accent/10 text-accent text-sm"
              >Hostinger</span
            >
          </div>
          <p class="text-muga-neutral relative z-20 mt-10">
            La tecnologia se define por funcion: carga rapida, base mantenible
            y control tecnico para escalar sin reordenar todo el sitio.
          </p>
        </BentoCell>

        <BentoCell
          title="SEO"
          colSpan="col-span-1 md:col-span-1"
          bgClass="bg-transparent"
          borderClass="border-white/5"
          rounded={false}
          lightEffect={true}
        >
          <IconWithBlurEffect 
            iconPath="/icons/scan-search.svg"
            iconAlt="Icono de SEO"
            iconKey="seo"
          />

          <ul class="space-y-2 text-muga-neutral relative z-10">
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Metadatos optimizados</span>
            </li>
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Estructura semántica</span>
            </li>
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Indexación mejorada</span>
            </li>
          </ul>
        </BentoCell>

        <BentoCell
          title="En pantalla"
          colSpan="col-span-1 md:col-span-2"
          bgClass="bg-transparent"
          borderClass="border-white/5"
          rounded={false}
          lightEffect={true}
        >
          <IconWithBlurEffect 
            iconPath="/icons/monitor-smartphone.svg"
            iconAlt="Icono de Responsive"
            iconKey="responsive"
          />
          
          <p class="text-muga-neutral">
            La estructura se define para sostener lectura y accion en cada
            ancho de pantalla, desde mobile hasta desktop.
          </p>
          <p class="mt-4 text-muga-neutral">
            No se trata solo de adaptar bloques. Se trata de mantener
            jerarquia, recorrido y claridad en cada contexto de uso.
          </p>
        </BentoCell>

        <BentoCell
          title="Mantenimiento"
          colSpan="col-span-1 md:col-span-1"
          bgClass="bg-transparent"
          borderClass="border-white/5"
          rounded={false}
          lightEffect={true}
        >
          <IconWithBlurEffect 
            iconPath="/icons/hard-hat.svg"
            iconAlt="Icono de Mantenimiento"
            iconKey="maintenance"
          />
          
          <ul class="space-y-2 text-muga-neutral relative z-10">
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Código limpio y documentado</span>
            </li>
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Actualizaciones controladas</span>
            </li>
            <li class="flex items-start">
              <span class="text-muga-primary mr-2">•</span>
              <span>Soporte técnico continuo</span>
            </li>
          </ul>
        </BentoCell>

        <BentoCell
          title="Siguiente paso"
          colSpan="col-span-1 md:col-span-1"
          bgClass="bg-transparent"
          borderClass="border-white/5"
          rounded={false}
          lightEffect={true}
        >
          <IconWithBlurEffect 
            iconPath="/icons/message-square-text.svg"
            iconAlt="Icono de Contacto"
            iconKey="contact"
          />
          
          <div class="flex flex-col space-y-4 relative z-10">
            <ArrowLink href="/contacto" text="Contanos tu caso" />
            <ArrowLink href="/formatos" text="Ver formatos" />
            <ArrowLink href="/casos" text="Ver referencias" />
          </div>
        </BentoCell>
      </div>
    </div>
  </section>
</Layout>

<script src="../../scripts/bento-grid.ts"></script>
