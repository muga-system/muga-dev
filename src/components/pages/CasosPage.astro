---
import Layout from "../../layouts/layout.astro";
import Navigation from "../ui/Navigation/Navigation.astro";
import Breadcrumb from "../ui/Breadcrumb/Breadcrumb.astro";
import PageHeroSection from "../HeroSection/PageHeroSection.astro";
import ArrowLink from "../ui/Button/ArrowLink.astro";
import type { BreadcrumbItem } from "../../types";

const breadcrumbItems: BreadcrumbItem[] = [
  {
    label: "Referencias",
    href: "/casos",
    active: true,
  },
];
---

<Layout title="Referencias | MUGA" description="Referencias de estructura aplicada a distintos objetivos.">
  <Navigation>
    <Breadcrumb slot="mobile-breadcrumb" items={breadcrumbItems} />
  </Navigation>
  <div class="hidden lg:block">
    <Breadcrumb items={breadcrumbItems} />
  </div>
  <PageHeroSection 
    title="Referencias"
    description="Todavía no mostramos casos de clientes. Acá podés ver referencias de estructura para entender cómo trabajamos."
    textAlign="left"
    showBadge={true}
    badgeText="Referencias"
  />

  <section class="relative px-6 py-16 lg:px-8 lg:py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10 max-w-3xl border border-white/10 bg-muga-dark-800/35 p-5 text-sm text-muga-neutral">
        Estas referencias no reemplazan un diagnóstico. Sirven para ver cómo cambia la estructura según el objetivo.
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <article class="flex h-full flex-col border border-white/10 bg-muga-dark-800/40 p-6">
          <p class="mb-3 font-mono text-xs uppercase tracking-[0.28em] text-accent">Referencia 01</p>
          <h2 class="text-2xl font-semibold text-white">Landing de conversión</h2>
          <p class="mt-4 flex-1 text-muga-neutral">
            Muestra cómo ordenamos una oferta puntual cuando todo apunta a una sola acción.
          </p>
          <div class="mt-6 space-y-2 text-sm text-muga-neutral">
            <p><span class="text-white font-semibold">Mirar:</span> hero, beneficio central y CTA.</p>
            <p><span class="text-white font-semibold">Sirve para:</span> campañas, servicios puntuales, captación directa.</p>
          </div>
          <a href="https://mugaland.vercel.app/" target="_blank" rel="noopener" class="mt-6 inline-flex w-fit items-center gap-2 border border-accent px-4 py-2 text-sm font-semibold text-accent transition-colors hover:bg-accent hover:text-obscure">
            Ver referencia
            <span aria-hidden="true">→</span>
          </a>
        </article>

        <article class="flex h-full flex-col border border-white/10 bg-muga-dark-800/40 p-6">
          <p class="mb-3 font-mono text-xs uppercase tracking-[0.28em] text-accent">Referencia 02</p>
          <h2 class="text-2xl font-semibold text-white">Sitio corporativo</h2>
          <p class="mt-4 flex-1 text-muga-neutral">
            Muestra cómo ordenamos una propuesta más amplia cuando hay que explicar mejor qué hace el negocio.
          </p>
          <div class="mt-6 space-y-2 text-sm text-muga-neutral">
            <p><span class="text-white font-semibold">Mirar:</span> recorrido de secciones, jerarquía de servicios y cierre de contacto.</p>
            <p><span class="text-white font-semibold">Sirve para:</span> presentar propuesta, ordenar servicios y sostener confianza.</p>
          </div>
          <a href="https://corporativo-astro.vercel.app/" target="_blank" rel="noopener" class="mt-6 inline-flex w-fit items-center gap-2 border border-accent px-4 py-2 text-sm font-semibold text-accent transition-colors hover:bg-accent hover:text-obscure">
            Ver referencia
            <span aria-hidden="true">→</span>
          </a>
        </article>

        <article class="flex h-full flex-col border border-white/10 bg-muga-dark-800/40 p-6">
          <p class="mb-3 font-mono text-xs uppercase tracking-[0.28em] text-accent">Referencia 03</p>
          <h2 class="text-2xl font-semibold text-white">Institucional y presencia</h2>
          <p class="mt-4 flex-1 text-muga-neutral">
            Muestra una estructura pensada para reforzar marca, ordenar información y sostener presencia.
          </p>
          <div class="mt-6 space-y-2 text-sm text-muga-neutral">
            <p><span class="text-white font-semibold">Mirar:</span> orden de información, confianza y claridad de lectura.</p>
            <p><span class="text-white font-semibold">Sirve para:</span> presencia de marca, servicios y comunicación institucional.</p>
          </div>
          <a href="https://muga-institucional.vercel.app/" target="_blank" rel="noopener" class="mt-6 inline-flex w-fit items-center gap-2 border border-accent px-4 py-2 text-sm font-semibold text-accent transition-colors hover:bg-accent hover:text-obscure">
            Ver referencia
            <span aria-hidden="true">→</span>
          </a>
        </article>
      </div>

      <div class="mt-12 border border-white/10 bg-muga-dark-800/35 p-6 sm:p-8">
        <h2 class="text-2xl font-semibold text-white">La referencia sirve para mirar. El diagnóstico sirve para decidir.</h2>
        <p class="mt-3 max-w-3xl text-muga-neutral">
          Si querés saber cuál se acerca más a tu caso, el siguiente paso es simple: contanos tu objetivo y te decimos qué conviene.
        </p>
        <div class="mt-6 flex flex-wrap gap-6">
          <ArrowLink href="/contacto" text="Quiero definir mi caso" />
          <ArrowLink href="/formatos" text="Ver formatos" />
        </div>
      </div>
    </div>
  </section>
</Layout>
