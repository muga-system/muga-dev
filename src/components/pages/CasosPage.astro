---
import Layout from "../../layouts/layout.astro";
import Navigation from "../ui/Navigation/Navigation.astro";
import Breadcrumb from "../ui/Breadcrumb/Breadcrumb.astro";
import PageHeroSection from "../HeroSection/PageHeroSection.astro";
import ArrowLink from "../ui/Button/ArrowLink.astro";
import type { BreadcrumbItem } from "../../types";

const breadcrumbItems: BreadcrumbItem[] = [
  {
    label: "Referencias",
    href: "/casos",
    active: true,
  },
];

type ClientCase = {
  label: string;
  name: string;
  description: string;
  domain: string;
  href: string;
  analyticsLabel: string;
};

type StructureReference = {
  label: string;
  title: string;
  description: string;
  lookAt: string;
  usefulFor: string;
  href: string;
};

const clientCases: ClientCase[] = [
  {
    label: "Cliente 01",
    name: "Dicorato",
    description: "Caso publicado con foco en presencia digital clara y recorrido de contenido orientado a conversión.",
    domain: "dicorato.com.ar",
    href: "https://www.dicorato.com.ar/",
    analyticsLabel: "dicorato",
  },
  {
    label: "Cliente 02",
    name: "El Método Adulma",
    description: "Caso publicado con estructura narrativa de oferta y secciones pensadas para explicar método y propuesta.",
    domain: "elmetodoadulma.com",
    href: "https://elmetodoadulma.com/",
    analyticsLabel: "el_metodo_adulma",
  },
];

const structureReferences: StructureReference[] = [
  {
    label: "Referencia 01",
    title: "Landing de conversión",
    description: "Muestra cómo ordenamos una oferta puntual cuando todo apunta a una sola acción.",
    lookAt: "hero, beneficio central y CTA.",
    usefulFor: "campañas, servicios puntuales, captación directa.",
    href: "https://mugaland.vercel.app/",
  },
  {
    label: "Referencia 02",
    title: "Sitio corporativo",
    description: "Muestra cómo ordenamos una propuesta más amplia cuando hay que explicar mejor qué hace el negocio.",
    lookAt: "recorrido de secciones, jerarquía de servicios y cierre de contacto.",
    usefulFor: "presentar propuesta, ordenar servicios y sostener confianza.",
    href: "https://corporativo-astro.vercel.app/",
  },
  {
    label: "Referencia 03",
    title: "Institucional y presencia",
    description: "Muestra una estructura pensada para reforzar marca, ordenar información y sostener presencia.",
    lookAt: "orden de información, confianza y claridad de lectura.",
    usefulFor: "presencia de marca, servicios y comunicación institucional.",
    href: "https://muga-institucional.vercel.app/",
  },
  {
    label: "Referencia 04",
    title: "Sitio de nicho: Bike",
    description: "Muestra una estructura orientada a catálogo visual y acción comercial clara para un negocio específico.",
    lookAt: "presentación de productos, jerarquía visual y llamados a la acción.",
    usefulFor: "negocios de nicho con foco en productos, servicios y consultas.",
    href: "https://muga-bike.vercel.app/",
  },
  {
    label: "Referencia 05",
    title: "Sitio de nicho: Barber",
    description: "Muestra una estructura centrada en servicios, confianza y conversión local con identidad marcada.",
    lookAt: "sección de servicios, pruebas de confianza y ruta de contacto.",
    usefulFor: "servicios locales que necesitan claridad, personalidad y más reservas.",
    href: "https://muga-barber.vercel.app/",
  },
];
---

<Layout title="Referencias | MUGA" description="Referencias de estructura aplicada a distintos objetivos.">
  <Navigation>
    <Breadcrumb slot="mobile-breadcrumb" items={breadcrumbItems} />
  </Navigation>
  <div class="hidden lg:block">
    <Breadcrumb items={breadcrumbItems} />
  </div>
  <PageHeroSection 
    title="Referencias"
    description="Acá podés ver casos de clientes publicados y referencias de estructura para entender cómo trabajamos."
    textAlign="left"
    showBadge={true}
    badgeText="Referencias"
  />

  <section class="section-space section-space-after-hero relative">
    <div class="page-container">
      <div class="mb-10 max-w-3xl border border-white/10 bg-muga-dark-800/35 p-5 text-sm text-muga-neutral">
        Los casos muestran sitios publicados. Las referencias muestran estructuras tipo. Todo se ajusta en la primera conversación.
      </div>

      <h2 class="mb-6 text-xl font-semibold text-white">Casos de clientes</h2>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {clientCases.map((item) => (
          <article class="flex h-full flex-col border border-white/10 bg-muga-dark-800/40 p-6">
            <p class="mb-3 font-mono text-xs uppercase tracking-[0.28em] text-accent">{item.label}</p>
            <h3 class="text-2xl font-semibold text-white">{item.name}</h3>
            <p class="mt-4 flex-1 text-muga-neutral">{item.description}</p>
            <div class="mt-6 space-y-2 text-sm text-muga-neutral">
              <p><span class="text-white font-semibold">Sitio:</span> {item.domain}</p>
            </div>
            <a href={item.href} target="_blank" rel="noopener" class="mt-6 inline-flex w-fit items-center gap-2 border border-accent px-4 py-2 text-sm font-semibold text-accent transition-colors hover:bg-accent hover:text-obscure" data-analytics-event="client_case_click" data-analytics-label={item.analyticsLabel} data-analytics-location="casos_clientes" data-analytics-step="casos" data-analytics-destination={item.href}>
              Ver sitio
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>

      <h2 class="mb-6 mt-12 text-xl font-semibold text-white">Referencias de estructura</h2>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {structureReferences.map((item) => (
          <article class="flex h-full flex-col border border-white/10 bg-muga-dark-800/40 p-6">
            <p class="mb-3 font-mono text-xs uppercase tracking-[0.28em] text-accent">{item.label}</p>
            <h3 class="text-2xl font-semibold text-white">{item.title}</h3>
            <p class="mt-4 flex-1 text-muga-neutral">{item.description}</p>
            <div class="mt-6 space-y-2 text-sm text-muga-neutral">
              <p><span class="text-white font-semibold">Mirar:</span> {item.lookAt}</p>
              <p><span class="text-white font-semibold">Sirve para:</span> {item.usefulFor}</p>
            </div>
            <a href={item.href} target="_blank" rel="noopener" class="mt-6 inline-flex w-fit items-center gap-2 border border-accent px-4 py-2 text-sm font-semibold text-accent transition-colors hover:bg-accent hover:text-obscure">
              Ver referencia
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>

      <div class="mt-12 border border-white/10 bg-muga-dark-800/35 p-6 sm:p-8">
        <h2 class="text-2xl font-semibold text-white">La referencia sirve para mirar. La conversación inicial sirve para decidir.</h2>
        <p class="mt-3 max-w-3xl text-muga-neutral">
          Si querés saber cuál se acerca más a tu caso, el siguiente paso es simple: contanos tu objetivo y te decimos qué conviene.
        </p>
        <div class="mt-6 flex flex-wrap gap-6">
          <ArrowLink href="/contacto" text="Quiero definir mi caso" />
          <ArrowLink href="/formatos" text="Ver formatos" />
        </div>
      </div>
    </div>
  </section>
</Layout>
