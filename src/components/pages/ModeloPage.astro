---
import ModeloBentoGrid from "../BentoGrid/ModeloBentoGrid.astro";
import Layout from "../../layouts/layout.astro";
import Navigation from "../ui/Navigation/Navigation.astro";
import Breadcrumb from "../ui/Breadcrumb/Breadcrumb.astro";
import PageHeroSection from "../HeroSection/PageHeroSection.astro";
import type { BreadcrumbItem } from "../../types";
import "../../styles/bento.css";

const breadcrumbItems: BreadcrumbItem[] = [
  {
    label: "Modelo",
    href: "/modelo",
    active: true,
  },
];
---

<Layout
  title="Modelo de trabajo | MUGA"
  description="Cómo definimos alcance, entregables y continuidad técnica."
>
  <Navigation>
    <Breadcrumb slot="mobile-breadcrumb" items={breadcrumbItems} />
  </Navigation>
  <div class="hidden lg:block">
    <Breadcrumb items={breadcrumbItems} />
  </div>
  <PageHeroSection
    title="Cómo trabajamos y qué definimos"
    description="Para que sepas qué definimos antes de avanzar y qué te llevás en cada paso."
    textAlign="left"
    showBadge={true}
    badgeText="Modelo"
  />
  <ModeloBentoGrid />

  <section class="section-space-bottom">
    <div class="page-container border border-white/5 bg-muga-dark-800/50 p-6 lg:p-8">
      <p class="max-w-3xl text-sm leading-7 text-muga-neutral">
        El alcance y el presupuesto no se definen a ciegas. Primero vemos tu objetivo, después definimos qué conviene y recién ahí bajamos una propuesta.
      </p>
    </div>
  </section>
</Layout>

<script>
  import "../../scripts/bento-grid.ts";
</script>
