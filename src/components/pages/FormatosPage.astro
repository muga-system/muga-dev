---
import Navigation from "../ui/Navigation/Navigation.astro";
import Breadcrumb from "../ui/Breadcrumb/Breadcrumb.astro";
import Layout from "../../layouts/layout.astro";
import PageHeroSection from "../HeroSection/PageHeroSection.astro";
import ArrowLink from "../ui/Button/ArrowLink.astro";
import type { BreadcrumbItem } from "../../types";

const breadcrumbItems: BreadcrumbItem[] = [
  {
    label: "Formatos",
    href: "/formatos",
    active: true,
  },
];
---

<Layout
  title="Formatos base | MUGA"
  description="Formatos base recomendados segun objetivo y nivel de alcance."
>
  <Navigation>
    <Breadcrumb slot="mobile-breadcrumb" items={breadcrumbItems} />
  </Navigation>
  <div class="hidden lg:block">
    <Breadcrumb items={breadcrumbItems} />
  </div>
  <PageHeroSection 
    title="Formatos base segun tu objetivo"
    description="Aca ves la diferencia entre una landing, un sitio corporativo y un sitio institucional."
    textAlign="left"
    showBadge={true}
    badgeText="Formatos"
  />
  <section class="relative px-6 py-16 lg:px-8 lg:py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 grid gap-4 border border-white/10 bg-muga-dark-800/35 p-5 text-sm text-muga-neutral md:grid-cols-3">
        <p><span class="text-white font-semibold">Landing:</span> una oferta, una accion.</p>
        <p><span class="text-white font-semibold">Corporativo:</span> propuesta, servicios y contacto.</p>
        <p><span class="text-white font-semibold">Institucional:</span> confianza, información y presencia.</p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <div class="flex flex-col items-start bg-muga-dark-800/70 border border-white/10 px-5 py-5 sm:px-7 sm:py-7">
          <img src="/products/edge.webp" alt="Landing Page" class="w-full h-40 object-cover mb-5 border border-white/10 sm:h-48" />
          <h2 class="text-xl font-semibold text-white mb-2 tracking-tight">Landing de conversión</h2>
          <p class="mb-4 text-left text-graylight">Para campanas, servicios puntuales o una sola propuesta.</p>
          <p class="mb-6 text-left text-sm text-muga-neutral">Ideal si queres llevar a la persona directo a la consulta con una sola accion principal.</p>
          <div class="w-full flex justify-start mt-auto">
            <a href="https://mugaland.vercel.app/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-accent border border-accent hover:bg-accent hover:text-obscure transition font-medium uppercase mb-2">Ver referencia <span aria-hidden="true">→</span></a>
          </div>
        </div>
        <div class="flex flex-col items-start bg-muga-dark-800/70 border border-white/10 px-5 py-5 sm:px-7 sm:py-7">
          <img src="/products/spark.webp" alt="Corporativo Astro" class="w-full h-40 object-cover mb-5 border border-white/10 sm:h-48" />
          <h2 class="text-xl font-semibold text-white mb-2 tracking-tight">Sitio corporativo</h2>
          <p class="mb-4 text-left text-graylight">Para presentar tu propuesta, explicar servicios y ordenar secciones.</p>
          <p class="mb-6 text-left text-sm text-muga-neutral">Ideal si necesitas mas contexto que una landing, sin perder foco comercial.</p>
          <div class="w-full flex justify-start mt-auto">
            <a href="https://corporativo-astro.vercel.app/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-accent border border-accent hover:bg-accent hover:text-obscure transition font-medium uppercase mb-2">Ver referencia <span aria-hidden="true">→</span></a>
          </div>
        </div>
        <div class="flex flex-col items-start bg-muga-dark-800/70 border border-white/10 px-5 py-5 sm:px-7 sm:py-7">
          <img src="/favicons/muga-institutional.svg" alt="MUGA Institucional" class="w-full h-40 object-contain mb-5 border border-white/10 p-4 bg-muga-dark-800/70 sm:h-48" />
          <h2 class="text-xl font-semibold text-white mb-2 tracking-tight">Sitio institucional</h2>
          <p class="mb-4 text-left text-graylight">Para ordenar información, construir confianza y sostener presencia.</p>
          <p class="mb-6 text-left text-sm text-muga-neutral">Ideal si necesitas una web mas estable que no dependa de una sola campana.</p>
          <div class="w-full flex justify-start mt-auto">
            <a href="https://muga-institucional.vercel.app/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-accent border border-accent hover:bg-accent hover:text-obscure transition font-medium uppercase mb-2">Ver referencia <span aria-hidden="true">→</span></a>
          </div>
        </div>
      </div>

      <div class="mt-12 border border-white/10 bg-muga-dark-800/35 p-6 sm:p-8">
        <h2 class="text-2xl font-semibold text-white">¿Querés ver más ejemplos antes de decidir?</h2>
        <p class="mt-3 max-w-3xl text-muga-neutral">
          Las referencias sirven para mirar estructuras aplicadas. El formato correcto se define en la primera conversacion.
        </p>
        <div class="mt-6">
          <ArrowLink href="/casos" text="Ver referencias" />
        </div>
      </div>

      <div class="mt-12 border border-white/10 bg-muga-dark-800/35 p-6 sm:p-8">
        <h2 class="text-2xl font-semibold text-white">¿No sabes cual elegir?</h2>
        <p class="mt-3 max-w-3xl text-muga-neutral">
          No hace falta que llegues con eso resuelto. En la primera conversacion te decimos que conviene hoy y por que.
        </p>
        <div class="mt-6">
          <ArrowLink href="/contacto" text="Quiero que me orienten" />
        </div>
      </div>
    </div>
  </section>
</Layout>
