---
import Navigation from "../ui/Navigation/Navigation.astro";
import Breadcrumb from "../ui/Breadcrumb/Breadcrumb.astro";
import Layout from "../../layouts/layout.astro";
import PageHeroSection from "../HeroSection/PageHeroSection.astro";
import type { BreadcrumbItem } from "../../types";

const breadcrumbItems: BreadcrumbItem[] = [
  {
    label: "Formatos",
    href: "/formatos",
    active: true,
  },
];
---

<Layout
  title="Formatos | MUGA"
  description="Estructuras base para distintos objetivos de conversion."
>
  <Navigation>
    <Breadcrumb items={breadcrumbItems} />
  </Navigation>
  <div class="hidden lg:block">
    <Breadcrumb items={breadcrumbItems} />
  </div>
  <PageHeroSection 
    title="Formatos de implementación"
    description="Bases estructurales para distintos objetivos de conversión."
    textAlign="left"
    showBadge={true}
    badgeText="Formatos"
  />
  <section class="relative px-6 py-16 lg:px-8 lg:py-24">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div class="flex flex-col items-start bg-muga-dark-800/70 border border-white/10 px-5 py-5 sm:px-7 sm:py-7">
          <img src="/products/edge.webp" alt="Landing Page" class="w-full h-40 object-cover mb-5 border border-white/10 sm:h-48" />
          <h2 class="text-xl font-semibold text-white mb-2 tracking-tight">Landing Page</h2>
          <p class="mb-6 text-left text-graylight">Una accion principal, menos friccion y una decision mas clara.</p>
          <div class="w-full flex justify-start mt-auto">
            <a href="https://mugaland.vercel.app/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-accent border border-accent hover:bg-accent hover:text-obscure transition font-medium uppercase mb-2">Ver formato <span aria-hidden="true">→</span></a>
          </div>
        </div>
        <div class="flex flex-col items-start bg-muga-dark-800/70 border border-white/10 px-5 py-5 sm:px-7 sm:py-7">
          <img src="/products/spark.webp" alt="Corporativo Astro" class="w-full h-40 object-cover mb-5 border border-white/10 sm:h-48" />
          <h2 class="text-xl font-semibold text-white mb-2 tracking-tight">Sitio corporativo</h2>
          <p class="mb-6 text-left text-graylight">Ordena propuesta, mensaje y recorrido de contacto.</p>
          <div class="w-full flex justify-start mt-auto">
            <a href="https://corporativo-astro.vercel.app/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-accent border border-accent hover:bg-accent hover:text-obscure transition font-medium uppercase mb-2">Ver formato <span aria-hidden="true">→</span></a>
          </div>
        </div>
        <div class="flex flex-col items-start bg-muga-dark-800/70 border border-white/10 px-5 py-5 sm:px-7 sm:py-7">
          <img src="/favicons/muga-electric-favicon.svg" alt="MUGA Electric" class="w-full h-40 object-contain mb-5 border border-white/10 p-4 bg-muga-dark-800/70 sm:h-48" />
          <h2 class="text-xl font-semibold text-white mb-2 tracking-tight">MUGA Electric</h2>
          <p class="mb-6 text-left text-graylight">Servicios claros, prioridad visible y contacto directo.</p>
          <div class="w-full flex justify-start mt-auto">
            <a href="https://muga-electric.vercel.app/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-accent border border-accent hover:bg-accent hover:text-obscure transition font-medium uppercase mb-2">Ver formato <span aria-hidden="true">→</span></a>
          </div>
        </div>
        <div class="flex flex-col items-start bg-muga-dark-800/70 border border-white/10 px-5 py-5 sm:px-7 sm:py-7">
          <img src="/favicons/muga-garden-favicon.svg" alt="MUGA Maran" class="w-full h-40 object-contain mb-5 border border-white/10 p-4 bg-muga-dark-800/70 sm:h-48" />
          <h2 class="text-xl font-semibold text-white mb-2 tracking-tight">MUGA Maran</h2>
          <p class="mb-6 text-left text-graylight">Marca, propuesta y contacto en un recorrido simple.</p>
          <div class="w-full flex justify-start mt-auto">
            <a href="https://muga-maran.vercel.app/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-accent border border-accent hover:bg-accent hover:text-obscure transition font-medium uppercase mb-2">Ver formato <span aria-hidden="true">→</span></a>
          </div>
        </div>
        <div class="flex flex-col items-start bg-muga-dark-800/70 border border-white/10 px-5 py-5 sm:px-7 sm:py-7">
          <img src="/favicons/muga-institutional.svg" alt="MUGA Institucional" class="w-full h-40 object-contain mb-5 border border-white/10 p-4 bg-muga-dark-800/70 sm:h-48" />
          <h2 class="text-xl font-semibold text-white mb-2 tracking-tight">Sitio institucional</h2>
          <p class="mb-6 text-left text-graylight">Servicios, confianza y contacto en una estructura estable.</p>
          <div class="w-full flex justify-start mt-auto">
            <a href="https://muga-institucional.vercel.app/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-accent border border-accent hover:bg-accent hover:text-obscure transition font-medium uppercase mb-2">Ver formato <span aria-hidden="true">→</span></a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
