---
export interface Props {
  title: string;
  description?: string;
  showBadge?: boolean;
  badgeText?: string;
  primaryButtonText?: string;
  primaryButtonLink?: string;
  secondaryButtonText?: string;
  secondaryButtonLink?: string;
  textAlign?: "left" | "center";
}

const {
  title,
  description = "",
  showBadge = false,
  badgeText = "muga dev",
  primaryButtonText = "",
  primaryButtonLink = "#",
  secondaryButtonText = "",
  secondaryButtonLink = "#",
  textAlign = "center"
} = Astro.props;

const textAlignClass = textAlign === "left" ? "text-left" : "text-center";
const buttonAlignClass = textAlign === "left" ? "justify-start" : "justify-center";
const contentWidthClass = textAlign === "left" ? "w-full max-w-xl sm:max-w-3xl" : "mx-auto w-full max-w-2xl";
const descriptionWidthClass = textAlign === "left" ? "max-w-xl sm:max-w-3xl" : "mx-auto max-w-2xl";
---

<section class="relative w-full">
  <div class="relative page-container">
      <div class={`${contentWidthClass} py-6 sm:py-8 lg:py-10`}>
        {showBadge && (
          <div class={`hidden sm:mb-4 sm:flex ${textAlign === "left" ? "sm:justify-start" : "sm:justify-center"}`}>
            <div class="muga-badge muga-badge--md">
              <span>{badgeText}</span>
            </div>
          </div>
        )}
        <div class={textAlignClass}>
          <h1
            class="max-w-4xl text-[2.5rem] font-semibold tracking-tight text-white sm:text-5xl lg:text-7xl"
          >
            {title}
          </h1>
          {description && (
            <p class={`mt-4 text-base font-medium text-pretty text-graylight sm:text-lg sm:leading-8 lg:text-xl/8 ${descriptionWidthClass}`}>
              {description}
            </p>
          )}
          {(primaryButtonText || secondaryButtonText) && (
            <div class={`mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center ${buttonAlignClass} sm:gap-x-6`}>
              {primaryButtonText && (
                <a
                  href={primaryButtonLink}
                  class="inline-flex w-full items-center justify-center border border-accent/50 bg-accent/5 px-3.5 py-2.5 text-sm font-semibold text-accent hover:bg-accent/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-obscure sm:w-auto"
                >
                  {primaryButtonText}
                </a>
              )}
              {secondaryButtonText && (
                <a href={secondaryButtonLink} class="secondary-link">
                  {secondaryButtonText} <span class="secondary-link__arrow">→</span>
                </a>
              )}
            </div>
          )}
        </div>
      </div>
  </div>
</section>
