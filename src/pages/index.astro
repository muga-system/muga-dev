---
import ArrowLink from "../components/ui/Button/ArrowLink.astro";
import {
  ArrowRight,
  ChartNoAxesCombined,
  ChevronRight,
  Layers,
  ListChecks,
  SquareArrowRight,
} from "@lucide/astro";

import Navigation from "../components/ui/Navigation/Navigation.astro";
import Layout from "../layouts/layout.astro";
import "../styles/bento.css";
---

<Layout
  title="MUGA - Arquitectura web para conversión"
  description="Conversión, jerarquía, flujo y secuencia aplicados a la estructura de tu web."
>
  <Navigation />

  <section class="relative -mt-12 grid min-h-[36rem] grid-rows-[1fr_auto_1fr] py-5 sm:min-h-[40rem] sm:py-6 lg:min-h-[46rem] lg:py-8">
    <div class="page-container row-start-2 self-center -translate-y-4 lg:-translate-y-6">
      <div class="max-w-5xl bg-muga-dark-800/30 px-6 py-8 sm:px-8 sm:py-10 lg:px-12 lg:py-12">
        <div class="mb-5 muga-badge muga-badge--md">
          muga dev
        </div>

        <h1 class="max-w-5xl text-4xl font-semibold leading-[0.94] tracking-tight text-white sm:text-6xl lg:text-[5.4rem]">
          Construimos sitios web con una estructura clara desde el inicio
        </h1>

        <p class="mt-5 max-w-3xl text-base leading-7 text-graylight sm:mt-6 sm:text-lg sm:leading-8 lg:text-xl/8">
          Cada proyecto se define según tu objetivo, para que el sitio tenga una base clara, ordenada y lista para crecer.
        </p>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href="/contacto"
            class="inline-flex w-full items-center justify-center gap-2 border border-accent/50 bg-accent/5 px-5 py-3 text-sm font-semibold text-accent transition-colors hover:bg-accent/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-obscure sm:w-auto"
            data-analytics-event="cta_click"
            data-analytics-label="contanos_tu_caso"
            data-analytics-location="home_hero"
            data-analytics-step="home"
            data-analytics-destination="/contacto"
          >
            Contanos tu caso
            <ArrowRight size={16} stroke-width={1.8} />
          </a>
          <a href="/modelo" class="secondary-link" data-analytics-event="cta_click" data-analytics-label="como_trabajamos" data-analytics-location="home_hero" data-analytics-step="home" data-analytics-destination="/modelo">
            Cómo trabajamos
            <span aria-hidden="true" class="secondary-link__arrow">→</span>
          </a>
        </div>

      </div>
    </div>
  </section>

  <section class="section-space section-space-after-hero relative">
    <div class="page-container">
      <div class="mb-10 max-w-3xl lg:mb-12">
        <div class="mb-4">
          <span class="muga-badge muga-badge--sm">Sistema</span>
        </div>
        <h2 class="section-title mb-4">
          La base con la que ordenamos cada sitio
        </h2>
        <p class="section-lead">
          Conversión, jerarquía, flujo y secuencia aplicados para que la web sea clara, ordenada y fácil de entender.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
        <div class="bg-muga-dark-800/50 border border-white/5 p-6 sm:p-7">
          <div class="mb-6 flex h-16 w-16 items-center justify-center border border-accent/50 bg-accent/5 text-accent sm:mb-7 sm:h-[4.5rem] sm:w-[4.5rem]">
            <ChartNoAxesCombined size={30} stroke-width={1.8} aria-hidden="true" />
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Conversión</h3>
          <p class="max-w-sm text-muga-neutral">Definimos qué tiene que pasar: consulta, venta o contacto.</p>
        </div>

        <div class="bg-muga-dark-800/50 border border-white/5 p-6 sm:p-7">
          <div class="mb-6 flex h-16 w-16 items-center justify-center border border-accent/50 bg-accent/5 text-accent sm:mb-7 sm:h-[4.5rem] sm:w-[4.5rem]">
            <Layers size={30} stroke-width={1.8} aria-hidden="true" />
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Jerarquía</h3>
          <p class="max-w-sm text-muga-neutral">Ordenamos qué se ve primero para que tu propuesta se entienda rápido.</p>
        </div>

        <div class="bg-muga-dark-800/50 border border-white/5 p-6 sm:p-7">
          <div class="mb-6 flex h-16 w-16 items-center justify-center border border-accent/50 bg-accent/5 text-accent sm:mb-7 sm:h-[4.5rem] sm:w-[4.5rem]">
            <SquareArrowRight size={30} stroke-width={1.8} aria-hidden="true" />
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Flujo</h3>
          <p class="max-w-sm text-muga-neutral">Armamos el recorrido para que la visita llegue a la acción sin trabas.</p>
        </div>

        <div class="bg-muga-dark-800/50 border border-white/5 p-6 sm:p-7">
          <div class="mb-6 flex h-16 w-16 items-center justify-center border border-accent/50 bg-accent/5 text-accent sm:mb-7 sm:h-[4.5rem] sm:w-[4.5rem]">
            <ListChecks size={30} stroke-width={1.8} aria-hidden="true" />
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Secuencia</h3>
          <p class="max-w-sm text-muga-neutral">Ponemos el contenido en el orden correcto para facilitar la decisión.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space relative bg-muga-dark-800/30">
    <div class="page-container">
      <div class="mb-10 max-w-3xl lg:mb-12">
        <div class="mb-4">
          <span class="muga-badge muga-badge--sm">Formatos</span>
        </div>
        <h2 class="section-title mb-4">
          Elegí el tipo de sitio según tu objetivo
        </h2>
        <p class="section-lead">
          Estos son los formatos más comunes. Si no sabés cuál conviene, lo definimos con vos antes de avanzar.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div class="flex flex-col bg-muga-dark-800/70 border border-white/10 px-4 py-4 sm:px-5 sm:py-5">
          <img src="/products/edge.webp" alt="Landing Page Moderna" width="1280" height="720" loading="lazy" decoding="async" class="w-full h-44 object-cover mb-4 border border-white/10 sm:h-48" />
          <h3 class="text-xl font-semibold text-white mb-2 tracking-tight">Landing de conversión</h3>
          <p class="mb-6 max-w-md text-graylight">Para una oferta, campaña o servicio con una sola acción principal.</p>
          <div class="w-full flex justify-start mt-auto">
            <a href="https://mugaland.vercel.app/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-accent border border-accent hover:bg-accent hover:text-obscure transition-colors font-medium uppercase mb-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-obscure">Ver referencia <span aria-hidden="true">→</span></a>
          </div>
        </div>

        <div class="flex flex-col bg-muga-dark-800/70 border border-white/10 px-4 py-4 sm:px-5 sm:py-5">
          <img src="/products/spark.webp" alt="Sitio Corporativo" width="1280" height="720" loading="lazy" decoding="async" class="w-full h-44 object-cover mb-4 border border-white/10 sm:h-48" />
          <h3 class="text-xl font-semibold text-white mb-2 tracking-tight">Sitio corporativo</h3>
          <p class="mb-6 max-w-md text-graylight">Para explicar mejor tu propuesta, mostrar servicios y sostener un recorrido más completo.</p>
          <div class="w-full flex justify-start mt-auto">
            <a href="https://corporativo-astro.vercel.app/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-accent border border-accent hover:bg-accent hover:text-obscure transition-colors font-medium uppercase mb-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-obscure">Ver referencia <span aria-hidden="true">→</span></a>
          </div>
        </div>
      </div>

      <div class="mt-12">
        <ArrowLink href="/formatos" text="Ver todos los formatos" analyticsEvent="content_navigation_click" analyticsLabel="ver_todos_los_formatos" analyticsLocation="home_formatos" analyticsStep="home" />
      </div>
    </div>
  </section>

  <section class="section-space relative">
    <div class="page-container">
      <div class="mb-10 max-w-3xl lg:mb-12">
        <div class="mb-4">
          <span class="muga-badge muga-badge--sm">Inversión</span>
        </div>
        <h2 class="section-title mb-4">
          Niveles de alcance para decidir más rápido
        </h2>
        <p class="section-lead">
          No son precios cerrados. Sirven para que sepas en qué nivel de proyecto estás antes de escribirnos.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <article class="flex h-full flex-col border border-white/10 bg-muga-dark-800/45 p-6">
          <p class="mb-4 font-mono text-xs uppercase tracking-[0.28em] text-accent">Alcance inicial</p>
          <h3 class="text-2xl font-semibold text-white">Base</h3>
          <p class="mt-3 flex-1 text-muga-neutral">
            Para una landing o una versión simple enfocada en una sola oferta.
          </p>
          <ul class="mt-6 space-y-2 text-sm text-muga-neutral">
            <li>Una acción principal.</li>
            <li>Estructura base clara.</li>
            <li>Ideal para salir rápido.</li>
          </ul>
        </article>

        <article class="flex h-full flex-col border border-white/10 bg-muga-dark-800/45 p-6">
          <p class="mb-4 font-mono text-xs uppercase tracking-[0.28em] text-accent">Alcance intermedio</p>
          <h3 class="text-2xl font-semibold text-white">Intermedio</h3>
          <p class="mt-3 flex-1 text-muga-neutral">
            Para un sitio corporativo con más recorrido, más contexto y mejor estructura comercial.
          </p>
          <ul class="mt-6 space-y-2 text-sm text-muga-neutral">
            <li>Más secciones y jerarquía.</li>
            <li>Recorrido de contacto más completo.</li>
            <li>Ideal para ordenar propuesta y servicios.</li>
          </ul>
        </article>

        <article class="flex h-full flex-col border border-white/10 bg-muga-dark-800/45 p-6">
          <p class="mb-4 font-mono text-xs uppercase tracking-[0.28em] text-accent">Alcance amplio</p>
          <h3 class="text-2xl font-semibold text-white">Avanzado</h3>
          <p class="mt-3 flex-1 text-muga-neutral">
            Para una estructura más amplia, con más personalización, más capas y continuidad técnica.
          </p>
          <ul class="mt-6 space-y-2 text-sm text-muga-neutral">
            <li>Mayor alcance y profundidad.</li>
            <li>Más personalización e integraciones.</li>
            <li>Ideal para una base pensada para crecer.</li>
          </ul>
        </article>
      </div>

      <p class="mt-8 max-w-4xl border-t border-white/10 pt-6 text-base leading-8 text-white">
        <span class="text-accent">No es una lista de precios.</span> Es una referencia para que puedas ubicar el alcance de tu proyecto antes de hablar con nosotros.
      </p>
    </div>
  </section>

  <section class="section-space relative bg-muga-dark-800/30">
    <div class="page-container">
      <div class="mb-10 max-w-3xl lg:mb-12">
        <div class="mb-4">
          <span class="muga-badge muga-badge--sm">FAQ</span>
        </div>
        <h2 class="section-title mb-4">
          Dudas comunes antes de avanzar
        </h2>
        <p class="section-lead">
          Estas preguntas suelen aparecer antes de contratar. Las resolvemos directo.
        </p>
      </div>

      <div class="space-y-4">
        <details class="border border-white/10 bg-muga-dark-800/45 p-5" open>
          <summary class="faq-summary">
            <span>No sé qué comprar</span>
            <ChevronRight class="faq-summary__icon" size={20} stroke-width={1.8} aria-hidden="true" />
          </summary>
          <p class="mt-3 max-w-3xl text-muga-neutral">
            No hace falta que lo sepas. Justamente por eso conviene escribirnos: vemos tu objetivo y te decimos qué formato tiene más sentido hoy.
          </p>
        </details>

        <details class="border border-white/10 bg-muga-dark-800/45 p-5">
          <summary class="faq-summary">
            <span>¿La consulta me obliga a contratar?</span>
            <ChevronRight class="faq-summary__icon" size={20} stroke-width={1.8} aria-hidden="true" />
          </summary>
          <p class="mt-3 max-w-3xl text-muga-neutral">
            No. La primera conversación ordena la decisión. Después decidís si avanzamos juntos, pero ya con más claridad.
          </p>
        </details>

        <details class="border border-white/10 bg-muga-dark-800/45 p-5">
          <summary class="faq-summary">
            <span>Ya tengo una web, ¿igual vale la pena?</span>
            <ChevronRight class="faq-summary__icon" size={20} stroke-width={1.8} aria-hidden="true" />
          </summary>
          <p class="mt-3 max-w-3xl text-muga-neutral">
            Sí. Si tu web actual no explica bien, no ordena la decisión o no te trae el tipo de consulta que buscás, hay algo para corregir.
          </p>
        </details>

        <details class="border border-white/10 bg-muga-dark-800/45 p-5">
          <summary class="faq-summary">
            <span>¿Tengo que hacer todo de una?</span>
            <ChevronRight class="faq-summary__icon" size={20} stroke-width={1.8} aria-hidden="true" />
          </summary>
          <p class="mt-3 max-w-3xl text-muga-neutral">
            No. Muchas veces conviene empezar con una versión más simple, resolver lo importante y crecer después sobre una base ordenada.
          </p>
        </details>

        <details class="border border-white/10 bg-muga-dark-800/45 p-5">
          <summary class="faq-summary">
            <span>¿Cuándo hablamos de inversión real?</span>
            <ChevronRight class="faq-summary__icon" size={20} stroke-width={1.8} aria-hidden="true" />
          </summary>
          <p class="mt-3 max-w-3xl text-muga-neutral">
            Después de la primera conversación. Primero definimos objetivo, formato y alcance. Recién ahí tiene sentido hablar de propuesta.
          </p>
        </details>
      </div>
    </div>
  </section>

  <section class="section-space relative">
    <div class="page-container">
      <div class="mb-10 max-w-3xl lg:mb-12">
        <div class="mb-4">
          <span class="muga-badge muga-badge--sm">Contacto</span>
        </div>
        <h2 class="section-title mb-4">
          Contanos tu caso y te orientamos con el formato
        </h2>
        <p class="section-lead mb-8">
          No hace falta que llegues con el formato resuelto. Con tu objetivo alcanza para ordenar el punto de partida y avanzar con una propuesta clara.
        </p>
      </div>

      <div class="w-full bg-muga-dark-800/50 border border-white/5 p-6 sm:p-8 lg:p-10">
        <div id="form-messages" class="mb-6 hidden">
          <div id="success-message" role="status" aria-live="polite" class="hidden bg-green-500/10 border border-green-500/20 text-green-400 px-4 py-3">
            Consulta enviada. Te contactamos por email.
          </div>
          <div id="error-message" role="status" aria-live="polite" class="hidden bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3">
            No pudimos enviar el formulario. Volvé a intentar.
          </div>
        </div>

        <form
          id="contact-form"
          method="POST"
          action="https://hook.us2.make.com/btf7mb88a3f5pkjrprjff44rsykxizfx"
          target="make-webhook-target"
          accept-charset="UTF-8"
          class="space-y-6"
        >
          <input type="hidden" name="created_at" value="" />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-white mb-2">Nombre</label>
              <input
                type="text"
                id="name"
                name="name"
                class="w-full px-3 py-2 bg-muga-dark-800/70 border border-white/10 text-white placeholder-graylight focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:border-transparent"
                placeholder="Tu nombre…"
                autocomplete="name"
                required
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-white mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-3 py-2 bg-muga-dark-800/70 border border-white/10 text-white placeholder-graylight focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:border-transparent"
                placeholder="tu@email.com…"
                autocomplete="email"
                autocapitalize="off"
                spellcheck="false"
                required
              />
            </div>
          </div>

          <div>
              <label for="phone" class="block text-sm font-medium text-white mb-2">Teléfono o WhatsApp</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-3 py-2 bg-muga-dark-800/70 border border-white/10 text-white placeholder-graylight focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:border-transparent"
              placeholder="+54 9 11 1234-5678…"
              autocomplete="tel"
              inputmode="tel"
            />
          </div>

          <div>
            <label for="project" class="block text-sm font-medium text-white mb-2">¿Qué tipo de sitio creés que necesitás? (opcional)</label>
            <select
              id="project"
              name="project"
              class="muga-select w-full px-3 py-2 bg-muga-dark-800/70 border border-white/10 text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:border-transparent"
              data-analytics-select
              data-analytics-context="home"
              autocomplete="off"
            >
              <option value="">No lo sé todavía</option>
              <option value="landing">Landing de conversión</option>
              <option value="corporativo">Sitio corporativo</option>
              <option value="institucional">Sitio institucional</option>
            </select>
          </div>

          <div>
            <label for="budget" class="block text-sm font-medium text-white mb-2">Rango de inversión orientativo (opcional)</label>
            <select
              id="budget"
              name="budget"
              class="muga-select w-full px-3 py-2 bg-muga-dark-800/70 border border-white/10 text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:border-transparent"
              data-analytics-select
              data-analytics-context="home"
              autocomplete="off"
            >
              <option value="">No lo sé todavía</option>
              <option value="start">Base</option>
              <option value="business">Intermedio</option>
              <option value="premium">Avanzado</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-white mb-2">Objetivo y problema actual</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full px-3 py-2 bg-muga-dark-800/70 border border-white/10 text-white placeholder-graylight focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:border-transparent"
              placeholder="Contanos qué vendés, qué querés lograr y qué te está frenando hoy…"
              autocomplete="off"
              required
            ></textarea>
          </div>

          <input type="hidden" name="page" value="" />
          <input type="hidden" name="source" value="website" />
          <input type="hidden" name="status" value="new" />
          <input type="hidden" name="lead_tier" value="undecided" />
          <input type="hidden" name="lead_stage" value="discovery" />
          <input type="hidden" name="lead_route" value="unspecified:undecided" />

          <div>
            <button
              type="submit"
              id="submit-btn"
              class="inline-flex w-full cursor-pointer items-center justify-center gap-2 border border-accent/70 bg-accent px-6 py-3 text-obscure font-semibold shadow-sm shadow-accent/10 hover:bg-accent/90 hover:shadow-md hover:shadow-accent/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-obscure disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:shadow-sm sm:w-auto"
            >
              <span id="btn-text">Enviar consulta</span>
              <span id="btn-arrow" aria-hidden="true">→</span>
              <div id="btn-spinner" class="hidden animate-spin rounded-full h-4 w-4 border-b-2 border-obscure" aria-hidden="true"></div>
            </button>
          </div>
        </form>
        <iframe id="make-webhook-target" name="make-webhook-target" class="hidden" aria-hidden="true"></iframe>
      </div>
    </div>
  </section>

</Layout>

<style>
  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    cursor: pointer;
    list-style: none;
    color: #fff;
    font-size: 1.125rem;
    font-weight: 600;
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-summary__icon {
    flex-shrink: 0;
    color: #ff5b5b;
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }

  details[open] .faq-summary__icon {
    transform: rotate(90deg);
  }
</style>

<script src="../scripts/contact-form-redirect.ts" defer></script>
