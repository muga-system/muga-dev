---
import Layout from "../layouts/layout.astro";
import Navigation from "../components/ui/Navigation/Navigation.astro";
import Breadcrumb from "../components/ui/Breadcrumb/Breadcrumb.astro";
import PageHeroSection from "../components/HeroSection/PageHeroSection.astro";
import ArrowLink from "../components/ui/Button/ArrowLink.astro";
import type { BreadcrumbItem } from "../types";

const breadcrumbItems: BreadcrumbItem[] = [
  {
    label: "Contacto",
    href: "/contacto",
    active: true,
  },
];
---

<Layout title="Contacto | MUGA" description="Contanos tu caso y te orientamos con una propuesta clara.">
  <Navigation>
    <Breadcrumb slot="mobile-breadcrumb" items={breadcrumbItems} />
  </Navigation>
  <div class="hidden lg:block">
    <Breadcrumb items={breadcrumbItems} />
  </div>
  <PageHeroSection
    title="Contanos tu caso"
    description="No hace falta que sepas qué tipo de sitio necesitás. Revisamos tu objetivo y te orientamos con una propuesta clara."
    textAlign="left"
    showBadge={true}
    badgeText="MUGA"
  />

  <section class="section-space section-space-after-hero relative">
    <div class="page-container">
      <div class="mb-14">
        <div class="mb-10 max-w-3xl lg:mb-12">
          <div class="mb-4">
            <span class="muga-badge muga-badge--sm">Proceso</span>
          </div>
          <h2 class="section-title">
            Así convertimos tu necesidad en una propuesta clara
          </h2>
          <p class="section-lead mt-4">
            Primero entendemos tu objetivo, después te recomendamos el formato y recién ahí avanzamos.
          </p>
        </div>

        <ol class="grid grid-cols-1 gap-6 md:grid-cols-3">
          <li class="flex h-full flex-col bg-muga-dark-800/40 border border-white/10 p-6 transition-colors duration-200 hover:border-accent/25 md:min-h-[320px] md:p-7">
            <div class="mb-6">
              <div class="flex h-16 w-16 items-center justify-center border border-accent/50 bg-accent/5 font-mono text-sm font-semibold tracking-[0.28em] text-accent md:h-[4.5rem] md:w-[4.5rem]">
                01
              </div>
            </div>
            <h3 class="mb-3 text-xl font-semibold tracking-tight text-white">Primera conversación</h3>
            <p class="mb-6 flex-1 text-base leading-7 text-white/75 md:mb-8 md:leading-8">Entendemos qué vendés, qué querés lograr y dónde hoy se traba la decisión.</p>
            <div class="space-y-3 pt-2 text-sm">
              <p><span class="text-accent font-mono uppercase text-[11px] tracking-wider">Tiempo:</span> <span class="text-white">30-45 min</span></p>
              <p><span class="text-accent font-mono uppercase text-[11px] tracking-wider">Resultado:</span> <span class="text-white">Lectura inicial del caso</span></p>
            </div>
          </li>

          <li class="flex h-full flex-col bg-muga-dark-800/40 border border-white/10 p-6 transition-colors duration-200 hover:border-accent/25 md:min-h-[320px] md:p-7">
            <div class="mb-6">
              <div class="flex h-16 w-16 items-center justify-center border border-accent/50 bg-accent/5 font-mono text-sm font-semibold tracking-[0.28em] text-accent md:h-[4.5rem] md:w-[4.5rem]">
                02
              </div>
            </div>
            <h3 class="mb-3 text-xl font-semibold tracking-tight text-white">Recomendación</h3>
            <p class="mb-6 flex-1 text-base leading-7 text-white/75 md:mb-8 md:leading-8">Te decimos qué tipo de sitio conviene, qué debería incluir y cuál es la primera versión razonable.</p>
            <div class="space-y-3 pt-2 text-sm">
              <p><span class="text-accent font-mono uppercase text-[11px] tracking-wider">Tiempo:</span> <span class="text-white">24-48 h</span></p>
              <p><span class="text-accent font-mono uppercase text-[11px] tracking-wider">Resultado:</span> <span class="text-white">Formato, jerarquía y alcance inicial</span></p>
            </div>
          </li>

          <li class="flex h-full flex-col bg-muga-dark-800/40 border border-white/10 p-6 transition-colors duration-200 hover:border-accent/25 md:min-h-[320px] md:p-7">
            <div class="mb-6">
              <div class="flex h-16 w-16 items-center justify-center border border-accent/50 bg-accent/5 font-mono text-sm font-semibold tracking-[0.28em] text-accent md:h-[4.5rem] md:w-[4.5rem]">
                03
              </div>
            </div>
            <h3 class="mb-3 text-xl font-semibold tracking-tight text-white">Implementación</h3>
            <p class="mb-6 flex-1 text-base leading-7 text-white/75 md:mb-8 md:leading-8">Si avanzamos, construimos la versión definida y dejamos una base lista para crecer sin rehacer.</p>
            <div class="space-y-3 pt-2 text-sm">
              <p><span class="text-accent font-mono uppercase text-[11px] tracking-wider">Tiempo:</span> <span class="text-white">Según alcance</span></p>
              <p><span class="text-accent font-mono uppercase text-[11px] tracking-wider">Resultado:</span> <span class="text-white">Sitio implementado</span></p>
            </div>
          </li>
        </ol>
      </div>

      <div class="bg-muga-dark-800/50 border border-white/5 p-6 sm:p-8 lg:p-10">
        <div class="mb-10 max-w-3xl">
          <div class="mb-4">
            <span class="muga-badge muga-badge--sm">Contacto</span>
          </div>
          <h2 class="section-title">
            Contanos tu caso y te guiamos en la compra
          </h2>
          <p class="section-lead mt-4">
            No hace falta que sepas qué formato elegir. Con tu objetivo alcanza para empezar.
          </p>
        </div>

        <div id="form-messages" class="mb-6 hidden">
          <div id="success-message" role="status" aria-live="polite" class="hidden bg-green-500/10 border border-green-500/20 text-green-400 px-4 py-3">
            Consulta enviada. Te contactamos por email.
          </div>
          <div id="error-message" role="status" aria-live="polite" class="hidden bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3">
            No pudimos enviar el formulario. Volvé a intentar.
          </div>
        </div>

        <form
          id="contact-form"
          method="POST"
          action="/api/contacto"
          accept-charset="UTF-8"
          class="space-y-6"
        >
          <input type="hidden" name="created_at" value="" />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-white mb-2">Nombre</label>
              <input
                type="text"
                id="name"
                name="name"
                class="w-full px-3 py-2 bg-muga-dark-800/70 border border-white/10 text-white placeholder-graylight focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:border-transparent"
                placeholder="Tu nombre…"
                autocomplete="name"
                required
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-white mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-3 py-2 bg-muga-dark-800/70 border border-white/10 text-white placeholder-graylight focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:border-transparent"
                placeholder="tu@email.com…"
                autocomplete="email"
                autocapitalize="off"
                spellcheck="false"
                required
              />
            </div>
          </div>

          <div>
              <label for="phone" class="block text-sm font-medium text-white mb-2">Teléfono o WhatsApp</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-3 py-2 bg-muga-dark-800/70 border border-white/10 text-white placeholder-graylight focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:border-transparent"
              placeholder="+54 9 11 1234-5678…"
              autocomplete="tel"
              inputmode="tel"
            />
          </div>

          <div>
            <label for="project" class="block text-sm font-medium text-white mb-2">¿Qué tipo de sitio creés que necesitás? (opcional)</label>
            <select
              id="project"
              name="project"
              class="muga-select w-full px-3 py-2 bg-muga-dark-800/70 border border-white/10 text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:border-transparent"
              data-analytics-select
              data-analytics-context="contacto"
              autocomplete="off"
            >
              <option value="">No lo sé todavía</option>
              <option value="landing">Landing de conversión</option>
              <option value="corporativo">Sitio corporativo</option>
              <option value="institucional">Sitio institucional</option>
            </select>
            <p class="mt-2 text-xs text-muga-neutral">Si no estás seguro, lo definimos juntos.</p>
          </div>

          <div>
            <label for="budget" class="block text-sm font-medium text-white mb-2">Rango de inversión orientativo (opcional)</label>
            <select
              id="budget"
              name="budget"
              class="muga-select w-full px-3 py-2 bg-muga-dark-800/70 border border-white/10 text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:border-transparent"
              data-analytics-select
              data-analytics-context="contacto"
              autocomplete="off"
            >
              <option value="">No lo sé todavía</option>
              <option value="start">Base</option>
              <option value="business">Intermedio</option>
              <option value="premium">Avanzado</option>
            </select>
            <p class="mt-2 text-xs text-muga-neutral">Nos ayuda a entender en qué nivel de alcance estás pensando.</p>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-white mb-2">Objetivo y problema actual</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full px-3 py-2 bg-muga-dark-800/70 border border-white/10 text-white placeholder-graylight focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:border-transparent"
              placeholder="Contanos qué vendés, qué querés lograr y qué te está frenando hoy…"
              autocomplete="off"
              required
            ></textarea>
          </div>

          <input type="hidden" name="page" value="" />
          <input type="hidden" name="landing_page" value="" />
          <input type="hidden" name="referrer" value="" />
          <input type="hidden" name="locale" value="" />
          <input type="hidden" name="timezone" value="" />
          <input type="hidden" name="user_agent" value="" />
          <input type="hidden" name="source" value="website" />
          <input type="hidden" name="utm_source" value="" />
          <input type="hidden" name="utm_medium" value="" />
          <input type="hidden" name="utm_campaign" value="" />
          <input type="hidden" name="utm_term" value="" />
          <input type="hidden" name="utm_content" value="" />
          <input type="hidden" name="gclid" value="" />
          <input type="hidden" name="fbclid" value="" />
          <input type="hidden" name="status" value="new" />
          <input type="hidden" name="lead_tier" value="undecided" />
          <input type="hidden" name="lead_stage" value="discovery" />
          <input type="hidden" name="lead_route" value="unspecified:undecided" />

          <div class="pt-2">
            <button
              type="submit"
              id="submit-btn"
              class="inline-flex cursor-pointer items-center gap-2 border border-accent/70 bg-accent px-6 py-3 text-obscure font-semibold shadow-sm shadow-accent/10 hover:bg-accent/90 hover:shadow-md hover:shadow-accent/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-obscure disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:shadow-sm"
            >
              <span id="btn-text">Enviar consulta</span>
              <span id="btn-arrow" aria-hidden="true">→</span>
              <div id="btn-spinner" class="hidden animate-spin rounded-full h-4 w-4 border-b-2 border-obscure" aria-hidden="true"></div>
            </button>
          </div>
        </form>
        <div id="contact-form-loading-overlay" class="form-loading-overlay" aria-hidden="true">
          <div class="form-loading-overlay__panel" role="status" aria-live="polite">
            <div class="form-loading-overlay__spinner" aria-hidden="true"></div>
            <p class="form-loading-overlay__text">Enviando consulta...</p>
          </div>
        </div>
      </div>

      <div class="mt-10 max-w-3xl">
        <p class="mb-4 text-sm text-muga-neutral">Si querés más contexto antes de escribirnos, revisá el modelo de trabajo, los formatos y algunas referencias.</p>
        <div class="flex flex-wrap gap-6">
          <ArrowLink href="/formatos" text="Formatos" analyticsEvent="content_navigation_click" analyticsLabel="formatos" analyticsLocation="contacto_context_links" analyticsStep="contacto" />
          <ArrowLink href="/casos" text="Referencias" analyticsEvent="content_navigation_click" analyticsLabel="referencias" analyticsLocation="contacto_context_links" analyticsStep="contacto" />
          <ArrowLink href="/modelo" text="Modelo" analyticsEvent="content_navigation_click" analyticsLabel="modelo" analyticsLocation="contacto_context_links" analyticsStep="contacto" />
        </div>
      </div>
    </div>
  </section>

  <script src="../scripts/contact-form-redirect.ts" defer></script>

</Layout>
