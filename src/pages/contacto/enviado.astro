---
import Layout from "../../layouts/layout.astro";
import Navigation from "../../components/ui/Navigation/Navigation.astro";
import Breadcrumb from "../../components/ui/Breadcrumb/Breadcrumb.astro";
import PageHeroSection from "../../components/HeroSection/PageHeroSection.astro";
import ArrowLink from "../../components/ui/Button/ArrowLink.astro";
import type { BreadcrumbItem } from "../../types";

const breadcrumbItems: BreadcrumbItem[] = [
  {
    label: "Contacto",
    href: "/contacto",
    active: false,
  },
  {
    label: "Enviado",
    href: "/contacto/enviado",
    active: true,
  },
];
---

<Layout title="Consulta enviada | MUGA" description="Confirmacion del envio del diagnostico.">
  <Navigation>
    <Breadcrumb items={breadcrumbItems} />
  </Navigation>
  <div class="hidden lg:block">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <PageHeroSection
    title="Diagnóstico enviado"
    description="Recibimos tu consulta. Revisa tu email para seguir con el proximo paso."
    textAlign="center"
    showBadge={true}
    badgeText="OK"
  />

  <section class="relative px-6 lg:px-8 py-24">
    <div class="mx-auto max-w-3xl">
      <div class="bg-muga-dark-800/50 border border-white/5 p-8 text-center">
        <div class="w-12 h-12 bg-accent/10 border border-accent/20 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-6 h-6 text-accent"
            aria-hidden="true"
          >
            <path d="M20 6L9 17l-5-5"></path>
          </svg>
        </div>

        <h2 class="section-title mb-4">Solicitud recibida</h2>
        <p class="section-lead mx-auto mb-8">
          El diagnostico fue enviado. Revisa tu email de contacto para seguir con el proximo paso.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10 text-left">
          <div class="border border-white/10 p-4">
            <div class="mb-2">
              <span class="muga-badge muga-badge--sm">Estado</span>
            </div>
            <p class="text-white text-sm">Recibido</p>
          </div>
          <div class="border border-white/10 p-4">
            <div class="mb-2">
              <span class="muga-badge muga-badge--sm">Siguiente paso</span>
            </div>
            <p class="text-white text-sm">Revisá tu email</p>
          </div>
          <div class="border border-white/10 p-4">
            <div class="mb-2">
              <span class="muga-badge muga-badge--sm">Canal</span>
            </div>
            <p class="text-white text-sm">Email de contacto</p>
          </div>
        </div>

        <div class="flex items-center justify-center">
          <ArrowLink href="/" text="Volver al inicio" />
        </div>
      </div>
    </div>
  </section>
</Layout>
