---
import Layout from "../layouts/layout.astro";
import Navigation from "../components/ui/Navigation/Navigation.astro";
import Breadcrumb from "../components/ui/Breadcrumb/Breadcrumb.astro";
import type { BreadcrumbItem } from "../types";
import {
  BadgeCheck,
  CircleCheck,
  CircleX,
  UserCheck,
} from "@lucide/astro";
import "maplibre-gl/dist/maplibre-gl.css";
import {
  METRICAS_SESSION_COOKIE,
  createMetricasSessionToken,
  isMetricasSessionValid,
} from "../lib/metricas-auth.js";

const breadcrumbItems: BreadcrumbItem[] = [
  {
    label: "Metricas",
    href: "/metricas",
    active: true,
  },
];

const supabaseUrl = import.meta.env.SUPABASE_URL;
const supabaseServiceRoleKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;
const leadsTable = import.meta.env.SUPABASE_LEADS_TABLE || "leads";
const panelPassword = process.env.METRICAS_PANEL_PASSWORD || import.meta.env.METRICAS_PANEL_PASSWORD;
const sessionSalt = process.env.METRICAS_SESSION_SALT || import.meta.env.METRICAS_SESSION_SALT || "muga-metricas-v1";

const method = Astro.request.method.toUpperCase();
let authError = panelPassword ? "" : "Falta configurar METRICAS_PANEL_PASSWORD en el servidor.";

if (method === "POST") {
  const formData = await Astro.request.formData();
  const action = String(formData.get("action") || "login");

  if (action === "logout") {
    Astro.cookies.delete(METRICAS_SESSION_COOKIE, { path: "/" });
    return Astro.redirect("/metricas");
  }

  const submittedPassword = String(formData.get("password") || "");

  if (!panelPassword) {
    authError = "Falta configurar METRICAS_PANEL_PASSWORD en el servidor.";
  } else if (submittedPassword && submittedPassword === panelPassword) {
    const sessionToken = createMetricasSessionToken(panelPassword, sessionSalt);
    Astro.cookies.set(METRICAS_SESSION_COOKIE, sessionToken, {
      path: "/",
      httpOnly: true,
      sameSite: "strict",
      secure: Astro.url.protocol === "https:",
      maxAge: 60 * 60 * 12,
    });
    return Astro.redirect("/metricas");
  } else {
    authError = "Clave invalida.";
  }
}

const sessionCookieValue = Astro.cookies.get(METRICAS_SESSION_COOKIE)?.value || "";
const isAuthorized = isMetricasSessionValid({
  cookieValue: sessionCookieValue,
  panelPassword,
  sessionSalt,
});

const parsePositiveInt = (value: string | null, fallback: number) => {
  const parsed = Number(value);
  if (!Number.isFinite(parsed) || parsed <= 0) return fallback;
  return Math.floor(parsed);
};

const estadoEtiquetas: Record<string, string> = {
  new: "Nuevo",
  contacted: "Contactado",
  qualified: "Calificado",
  won: "Cerrado",
  lost: "Perdido",
};

const getLeadTier = (lead: { lead_stage?: string; budget?: string }) => {
  const stage = String(lead?.lead_stage || "").toLowerCase();
  const budget = String(lead?.budget || "").toLowerCase();
  if (stage === "high-intent" || budget === "premium") return "alto";
  if (stage === "qualified" || budget === "business") return "calificado";
  return "nuevo";
};

const formatDay = (date: Date) =>
  date.toLocaleDateString("es-AR", {
    day: "2-digit",
    month: "2-digit",
  });

const formatHours = (value: number) => {
  if (!Number.isFinite(value) || value <= 0) return "0 h";
  if (value < 1) return `${Math.round(value * 60)} min`;
  return `${value.toFixed(1)} h`;
};

const humanizeAttribution = (value?: string) => {
  const normalized = String(value || "").trim().toLowerCase();
  if (!normalized) return "Sin dato";
  if (normalized === "sin_utm") return "Sin UTM";
  if (normalized === "sin_campana") return "Sin campaña";
  if (normalized === "none") return "Directo";
  return normalized.replace(/[_-]+/g, " ");
};

const parseHourFromDate = (date: Date, timezone?: string) => {
  if (Number.isNaN(date.getTime())) return 0;
  if (!timezone) return date.getUTCHours();
  try {
    const parts = new Intl.DateTimeFormat("en-GB", {
      hour: "2-digit",
      hour12: false,
      timeZone: timezone,
    }).formatToParts(date);
    const hourPart = parts.find((part) => part.type === "hour")?.value || "0";
    const parsed = Number(hourPart);
    return Number.isFinite(parsed) ? Math.max(0, Math.min(23, parsed)) : 0;
  } catch {
    return date.getUTCHours();
  }
};

const countryFromLocale = (locale?: string) => {
  const value = String(locale || "").trim();
  if (!value.includes("-")) return "";
  const code = value.split("-").pop() || "";
  return code.length === 2 ? code.toUpperCase() : "";
};

const COUNTRY_FROM_TIMEZONE_PREFIX: Record<string, string> = {
  "America/Argentina": "AR",
  "America/Buenos_Aires": "AR",
  "America/Sao_Paulo": "BR",
  "America/Santiago": "CL",
  "America/Bogota": "CO",
  "America/Lima": "PE",
  "America/Montevideo": "UY",
  "America/Mexico_City": "MX",
  "America/New_York": "US",
  "America/Los_Angeles": "US",
  "America/Toronto": "CA",
  "Europe/Madrid": "ES",
  "Europe/Lisbon": "PT",
  "Europe/Paris": "FR",
  "Europe/Berlin": "DE",
  "Europe/Rome": "IT",
  "Europe/London": "GB",
  "Australia/Sydney": "AU",
};

const countryFromTimezone = (timezone?: string) => {
  const value = String(timezone || "").trim();
  if (!value) return "";
  const exact = COUNTRY_FROM_TIMEZONE_PREFIX[value];
  if (exact) return exact;
  const prefixed = Object.entries(COUNTRY_FROM_TIMEZONE_PREFIX).find(([prefix]) => value.startsWith(prefix));
  return prefixed ? prefixed[1] : "";
};

const normalizeCountryCode = (value?: string) => {
  const code = String(value || "").trim().toUpperCase();
  if (code.length !== 2) return "";
  return /^[A-Z]{2}$/.test(code) ? code : "";
};

const inferLeadCountry = (lead: { ip_country?: string; locale?: string; timezone?: string }) => {
  return (
    normalizeCountryCode(lead.ip_country) ||
    normalizeCountryCode(countryFromLocale(lead.locale)) ||
    normalizeCountryCode(countryFromTimezone(lead.timezone)) ||
    "ZZ"
  );
};

const COUNTRY_COORDS: Record<string, { lon: number; lat: number; label: string }> = {
  AR: { lon: -64, lat: -34, label: "Argentina" },
  BR: { lon: -52, lat: -10, label: "Brasil" },
  CL: { lon: -71, lat: -33, label: "Chile" },
  UY: { lon: -56, lat: -32, label: "Uruguay" },
  PY: { lon: -58, lat: -23, label: "Paraguay" },
  BO: { lon: -64, lat: -17, label: "Bolivia" },
  US: { lon: -98, lat: 39, label: "Estados Unidos" },
  CA: { lon: -106, lat: 56, label: "Canada" },
  MX: { lon: -102, lat: 23, label: "Mexico" },
  ES: { lon: -3, lat: 40, label: "Espana" },
  PT: { lon: -8, lat: 39, label: "Portugal" },
  FR: { lon: 2, lat: 47, label: "Francia" },
  DE: { lon: 10, lat: 51, label: "Alemania" },
  IT: { lon: 12, lat: 42, label: "Italia" },
  GB: { lon: -2, lat: 54, label: "Reino Unido" },
  CO: { lon: -74, lat: 4, label: "Colombia" },
  PE: { lon: -75, lat: -9, label: "Peru" },
  AU: { lon: 134, lat: -25, label: "Australia" },
  ZZ: { lon: 160, lat: -50, label: "Sin dato" },
};

const diasOpciones = [1, 7, 30, 90];

const selectedDays = parsePositiveInt(Astro.url.searchParams.get("dias"), 30);
const selectedStatus = (Astro.url.searchParams.get("estado") || "all").toLowerCase();
const selectedSource = (Astro.url.searchParams.get("fuente") || "all").toLowerCase();
const selectedUtmSource = (Astro.url.searchParams.get("utm_source") || "all").toLowerCase();
const selectedUtmCampaign = (Astro.url.searchParams.get("utm_campaign") || "all").toLowerCase();
const selectedQuickStatus = (Astro.url.searchParams.get("quick_status") || "new").toLowerCase();
const statusUpdateResult = (Astro.url.searchParams.get("status_update") || "").toLowerCase();
const exportCsvParams = new URLSearchParams({
  dias: String(selectedDays),
  estado: selectedStatus,
  fuente: selectedSource,
  utm_source: selectedUtmSource,
  utm_campaign: selectedUtmCampaign,
});
const exportCsvHref = `/api/leads/export.csv?${exportCsvParams.toString()}`;
const cleanReturnParams = new URLSearchParams(Astro.url.searchParams);
cleanReturnParams.delete("status_update");
const returnToSearch = cleanReturnParams.toString();
const returnToParam = returnToSearch ? `/metricas?${returnToSearch}` : "/metricas";

let loadError = "";

const metrics = {
  total: 0,
  enPeriodo: 0,
  byStatus: {
    new: 0,
    contacted: 0,
    qualified: 0,
    won: 0,
    lost: 0,
  },
  byTier: {
    alto: 0,
    calificado: 0,
    nuevo: 0,
  },
  sources: [] as Array<{ source: string; count: number }>,
  attribution: {
    utmSources: [] as Array<{ source: string; count: number }>,
    utmCampaigns: [] as Array<{ campaign: string; count: number }>,
  },
  contactTiming: {
    avgHoursToFirstContact: 0,
    contactedWithin24h: 0,
    measuredLeads: 0,
  },
  activityByHour: Array.from({ length: 24 }, (_, hour) => ({ hour, total: 0 })),
  countries: [] as Array<{ code: string; label: string; count: number; lon: number; lat: number }>,
};

const funnel = {
  contactRate: 0,
  qualificationRate: 0,
  winRate: 0,
};

const tendencia: Array<{ dia: string; total: number }> = [];
const fuentesDisponibles: string[] = [];
const utmSourcesDisponibles: string[] = [];
const utmCampaignsDisponibles: string[] = [];
const leadsRecientes: Array<{
  id: number;
  createdAt: string;
  name: string;
  email: string;
  status: string;
  project: string;
}> = [];
const bandejaHoy: Array<{
  id: number;
  createdAt: string;
  name: string;
  email: string;
  project: string;
  ageHours: number;
  urgency: "normal" | "warning" | "critico";
}> = [];
const bandejaResumen = {
  total: 0,
  normal: 0,
  warning: 0,
  critico: 0,
};

if (!isAuthorized) {
  loadError = "";
} else if (!supabaseUrl || !supabaseServiceRoleKey) {
  loadError = "Faltan variables de servidor para cargar metricas.";
} else {
  const cutoffIso = new Date(Date.now() - selectedDays * 24 * 60 * 60 * 1000).toISOString();

  const selectCandidates = [
    "id,created_at,name,email,project,status,lead_stage,budget,source,utm_source,utm_medium,utm_campaign,first_contact_at,timezone,locale,ip_country",
    "id,created_at,name,email,project,status,lead_stage,budget,source,utm_source,utm_medium,utm_campaign,timezone,locale",
    "id,created_at,name,email,project,status,lead_stage,budget,source,timezone,locale",
    "id,created_at,name,email,project,status,lead_stage,budget,source",
  ];

  let rows: Array<{
    created_at?: string;
    id?: number;
    name?: string;
    email?: string;
    project?: string;
    status?: string;
    lead_stage?: string;
    budget?: string;
    source?: string;
    utm_source?: string;
    utm_medium?: string;
    utm_campaign?: string;
    first_contact_at?: string;
    timezone?: string;
    locale?: string;
    ip_country?: string;
  }> | null = null;
  let lastStatus = 500;

  for (const select of selectCandidates) {
    const query = new URL(`${supabaseUrl}/rest/v1/${leadsTable}`);
    query.searchParams.set("select", select);
    query.searchParams.set("created_at", `gte.${cutoffIso}`);
    query.searchParams.set("order", "created_at.desc");
    query.searchParams.set("limit", "5000");

    const response = await fetch(query.toString(), {
      headers: {
        apikey: supabaseServiceRoleKey,
        Authorization: `Bearer ${supabaseServiceRoleKey}`,
      },
    });

    lastStatus = response.status;
    if (response.ok) {
      rows = (await response.json()) as Array<{
        created_at?: string;
        id?: number;
        name?: string;
        email?: string;
        project?: string;
        status?: string;
        lead_stage?: string;
        budget?: string;
        source?: string;
        utm_source?: string;
        utm_medium?: string;
        utm_campaign?: string;
        first_contact_at?: string;
        timezone?: string;
        locale?: string;
        ip_country?: string;
      }>;
      break;
    }

    if (response.status !== 400) break;
  }

  if (!rows) {
    loadError = `No se pudieron cargar metricas (${lastStatus}).`;
  } else {
    const safeRows = rows as Array<{
      created_at?: string;
      id?: number;
      name?: string;
      email?: string;
      project?: string;
      status?: string;
      lead_stage?: string;
      budget?: string;
      source?: string;
      utm_source?: string;
      utm_medium?: string;
      utm_campaign?: string;
      first_contact_at?: string;
      timezone?: string;
      locale?: string;
      ip_country?: string;
    }>;

    const allSourceCounter = new Map<string, number>();
    const allUtmSourceCounter = new Map<string, number>();
    const allUtmCampaignCounter = new Map<string, number>();

    metrics.enPeriodo = safeRows.length;

    safeRows.forEach((lead) => {
      const source = String(lead.source || "desconocido").toLowerCase();
      const utmSource = String(lead.utm_source || "sin_utm").trim().toLowerCase();
      const utmCampaign = String(lead.utm_campaign || "sin_campana").trim().toLowerCase();
      allSourceCounter.set(source, (allSourceCounter.get(source) || 0) + 1);
      allUtmSourceCounter.set(utmSource, (allUtmSourceCounter.get(utmSource) || 0) + 1);
      allUtmCampaignCounter.set(utmCampaign, (allUtmCampaignCounter.get(utmCampaign) || 0) + 1);
    });

    fuentesDisponibles.push(...[...allSourceCounter.keys()].sort());
    utmSourcesDisponibles.push(...[...allUtmSourceCounter.keys()].sort());
    utmCampaignsDisponibles.push(...[...allUtmCampaignCounter.keys()].sort());

    const filteredRows = safeRows.filter((lead) => {
      const status = String(lead.status || "new").toLowerCase();
      const source = String(lead.source || "desconocido").toLowerCase();
      const utmSource = String(lead.utm_source || "sin_utm").trim().toLowerCase();
      const utmCampaign = String(lead.utm_campaign || "sin_campana").trim().toLowerCase();

      if (selectedStatus !== "all" && status !== selectedStatus) return false;
      if (selectedSource !== "all" && source !== selectedSource) return false;
      if (selectedUtmSource !== "all" && utmSource !== selectedUtmSource) return false;
      if (selectedUtmCampaign !== "all" && utmCampaign !== selectedUtmCampaign) return false;
      return true;
    });

    const newQueueRows = safeRows
      .filter((lead) => {
        const status = String(lead.status || "new").toLowerCase();
        const source = String(lead.source || "desconocido").toLowerCase();
        const utmSource = String(lead.utm_source || "sin_utm").trim().toLowerCase();
        const utmCampaign = String(lead.utm_campaign || "sin_campana").trim().toLowerCase();

        if (status !== "new") return false;
        if (selectedSource !== "all" && source !== selectedSource) return false;
        if (selectedUtmSource !== "all" && utmSource !== selectedUtmSource) return false;
        if (selectedUtmCampaign !== "all" && utmCampaign !== selectedUtmCampaign) return false;
        return true;
      })
      .map((lead) => {
        const createdDate = new Date(String(lead.created_at || ""));
        const ageHours = Number.isNaN(createdDate.getTime())
          ? 0
          : Math.max(0, (Date.now() - createdDate.getTime()) / (1000 * 60 * 60));
        const urgency: "normal" | "warning" | "critico" =
          ageHours >= 48 ? "critico" : ageHours >= 24 ? "warning" : "normal";

        return {
          lead,
          createdDate,
          ageHours,
          urgency,
        };
      })
      .sort((a, b) => b.ageHours - a.ageHours);

    bandejaResumen.total = newQueueRows.length;
    bandejaResumen.normal = newQueueRows.filter((row) => row.urgency === "normal").length;
    bandejaResumen.warning = newQueueRows.filter((row) => row.urgency === "warning").length;
    bandejaResumen.critico = newQueueRows.filter((row) => row.urgency === "critico").length;

    newQueueRows.slice(0, 15).forEach(({ lead, createdDate, ageHours, urgency }) => {
      const createdAt = Number.isNaN(createdDate.getTime())
        ? "-"
        : createdDate.toLocaleString("es-AR", {
            dateStyle: "short",
            timeStyle: "short",
          });

      bandejaHoy.push({
        id: Number(lead.id || 0),
        createdAt,
        name: String(lead.name || "Sin nombre"),
        email: String(lead.email || "sin-email"),
        project: String(lead.project || "-"),
        ageHours,
        urgency,
      });
    });

    metrics.total = filteredRows.length;
    const filteredSourceCounter = new Map<string, number>();
    const filteredDaily = new Map<string, number>();
    const filteredUtmSourceCounter = new Map<string, number>();
    const filteredUtmCampaignCounter = new Map<string, number>();
    const filteredCountryCounter = new Map<string, number>();
    const hourlyCounter = Array.from({ length: 24 }, () => 0);
    let firstContactHoursTotal = 0;
    let firstContactMeasured = 0;
    let firstContactWithin24h = 0;

    filteredRows.forEach((lead) => {
      const status = String(lead.status || "new").toLowerCase();
      const source = String(lead.source || "desconocido").toLowerCase();
      const utmSource = String(lead.utm_source || "sin_utm").trim().toLowerCase();
      const utmCampaign = String(lead.utm_campaign || "sin_campana").trim().toLowerCase();

      if (status in metrics.byStatus) {
        metrics.byStatus[status as keyof typeof metrics.byStatus] += 1;
      }

      const tier = getLeadTier(lead);
      metrics.byTier[tier as keyof typeof metrics.byTier] += 1;

      filteredSourceCounter.set(source, (filteredSourceCounter.get(source) || 0) + 1);
      filteredUtmSourceCounter.set(utmSource, (filteredUtmSourceCounter.get(utmSource) || 0) + 1);
      filteredUtmCampaignCounter.set(utmCampaign, (filteredUtmCampaignCounter.get(utmCampaign) || 0) + 1);

      const createdDate = new Date(String(lead.created_at || ""));
      if (!Number.isNaN(createdDate.getTime())) {
        const key = createdDate.toISOString().slice(0, 10);
        filteredDaily.set(key, (filteredDaily.get(key) || 0) + 1);

        const leadHour = parseHourFromDate(createdDate, String(lead.timezone || ""));
        hourlyCounter[leadHour] += 1;
      }

      const countryCode = inferLeadCountry(lead);
      filteredCountryCounter.set(countryCode, (filteredCountryCounter.get(countryCode) || 0) + 1);

      const firstContactRaw = String(lead.first_contact_at || "");
      if (firstContactRaw) {
        const firstContactDate = new Date(firstContactRaw);
        if (!Number.isNaN(firstContactDate.getTime()) && !Number.isNaN(createdDate.getTime())) {
          const diffHours = (firstContactDate.getTime() - createdDate.getTime()) / (1000 * 60 * 60);
          if (diffHours >= 0) {
            firstContactMeasured += 1;
            firstContactHoursTotal += diffHours;
            if (diffHours <= 24) firstContactWithin24h += 1;
          }
        }
      }
    });

    filteredRows
      .filter((lead) => {
        const leadStatus = String(lead.status || "new").toLowerCase();
        return selectedQuickStatus === "all" || leadStatus === selectedQuickStatus;
      })
      .slice(0, 12)
      .forEach((lead) => {
      const leadStatus = String(lead.status || "new").toLowerCase();

      const createdDate = new Date(String(lead.created_at || ""));
      const createdAt = Number.isNaN(createdDate.getTime())
        ? "-"
        : createdDate.toLocaleString("es-AR", {
            dateStyle: "short",
            timeStyle: "short",
          });

        leadsRecientes.push({
          id: Number(lead.id || 0),
          createdAt,
          name: String(lead.name || "Sin nombre"),
          email: String(lead.email || "sin-email"),
          status: leadStatus,
          project: String(lead.project || "-"),
        });
      });

    metrics.sources = [...filteredSourceCounter.entries()]
      .map(([source, count]) => ({ source, count }))
      .sort((a, b) => b.count - a.count)
      .slice(0, 8);

    metrics.attribution.utmSources = [...filteredUtmSourceCounter.entries()]
      .map(([source, count]) => ({ source, count }))
      .sort((a, b) => b.count - a.count)
      .slice(0, 24);

    metrics.attribution.utmCampaigns = [...filteredUtmCampaignCounter.entries()]
      .map(([campaign, count]) => ({ campaign, count }))
      .sort((a, b) => b.count - a.count)
      .slice(0, 40);

    metrics.contactTiming.measuredLeads = firstContactMeasured;
    metrics.contactTiming.avgHoursToFirstContact = firstContactMeasured
      ? Number((firstContactHoursTotal / firstContactMeasured).toFixed(2))
      : 0;
    metrics.contactTiming.contactedWithin24h = firstContactMeasured
      ? Number(((firstContactWithin24h / firstContactMeasured) * 100).toFixed(1))
      : 0;

    metrics.activityByHour = hourlyCounter.map((total, hour) => ({ hour, total }));

    metrics.countries = [...filteredCountryCounter.entries()]
      .map(([code, count]) => {
        const coord = COUNTRY_COORDS[code] || COUNTRY_COORDS.ZZ;
        return {
          code,
          count,
          label: coord.label,
          lon: coord.lon,
          lat: coord.lat,
        };
      })
      .sort((a, b) => b.count - a.count)
      .slice(0, 8);

    const contactedOrMore =
      metrics.byStatus.contacted +
      metrics.byStatus.qualified +
      metrics.byStatus.won +
      metrics.byStatus.lost;
    const qualifiedOrMore = metrics.byStatus.qualified + metrics.byStatus.won;

    funnel.contactRate = metrics.total
      ? Number(((contactedOrMore / metrics.total) * 100).toFixed(1))
      : 0;
    funnel.qualificationRate = metrics.total
      ? Number(((qualifiedOrMore / metrics.total) * 100).toFixed(1))
      : 0;
    funnel.winRate = metrics.total
      ? Number(((metrics.byStatus.won / metrics.total) * 100).toFixed(1))
      : 0;

    const maxBars = Math.min(selectedDays, 14);
    const dayMs = 24 * 60 * 60 * 1000;
    for (let i = maxBars - 1; i >= 0; i--) {
      const day = new Date(Date.now() - i * dayMs);
      const isoKey = day.toISOString().slice(0, 10);
      tendencia.push({
        dia: formatDay(day),
        total: filteredDaily.get(isoKey) || 0,
      });
    }
  }
}

const estadoItems = [
  { key: "new", label: "Nuevo", value: metrics.byStatus.new },
  { key: "contacted", label: "Contactado", value: metrics.byStatus.contacted },
  { key: "qualified", label: "Calificado", value: metrics.byStatus.qualified },
  { key: "won", label: "Cerrado", value: metrics.byStatus.won },
  { key: "lost", label: "Perdido", value: metrics.byStatus.lost },
];

const prioridadItems = [
  { key: "alto", label: "Alta", value: metrics.byTier.alto },
  { key: "calificado", label: "Media", value: metrics.byTier.calificado },
  { key: "nuevo", label: "Normal", value: metrics.byTier.nuevo },
];

const maxEstado = Math.max(1, ...estadoItems.map((item) => item.value));
const maxPrioridad = Math.max(1, ...prioridadItems.map((item) => item.value));
const maxTendencia = Math.max(1, ...tendencia.map((item) => item.total));
const maxActividadHora = Math.max(1, ...metrics.activityByHour.map((item) => item.total));
const topUtmSourceItems = metrics.attribution.utmSources.slice(0, 6);
const overflowUtmSourceItems = metrics.attribution.utmSources.slice(6);
const topUtmCampaignItems = metrics.attribution.utmCampaigns.slice(0, 6);
const overflowUtmCampaignItems = metrics.attribution.utmCampaigns.slice(6);
const urgencyLabels = {
  normal: "En tiempo",
  warning: "Warning >24h",
  critico: "Critico >48h",
};
const urgencyClass = {
  normal: "border-emerald-500/30 bg-emerald-500/10 text-emerald-300",
  warning: "border-amber-500/30 bg-amber-500/10 text-amber-300",
  critico: "border-red-500/30 bg-red-500/10 text-red-300",
};
const quickActionsByStatus: Record<string, Array<{ value: string; label: string; className: string }>> = {
  new: [
    {
      value: "contacted",
      label: "Contactado",
      className: "border-emerald-500/40 bg-emerald-500/10 text-emerald-200 hover:bg-emerald-500/20",
    },
    {
      value: "qualified",
      label: "Calificado",
      className: "border-blue-500/40 bg-blue-500/10 text-blue-200 hover:bg-blue-500/20",
    },
    {
      value: "lost",
      label: "Perdido",
      className: "border-red-500/40 bg-red-500/10 text-red-200 hover:bg-red-500/20",
    },
  ],
  contacted: [
    {
      value: "qualified",
      label: "Calificado",
      className: "border-blue-500/40 bg-blue-500/10 text-blue-200 hover:bg-blue-500/20",
    },
    {
      value: "won",
      label: "Cerrado",
      className: "border-emerald-500/40 bg-emerald-500/10 text-emerald-200 hover:bg-emerald-500/20",
    },
    {
      value: "lost",
      label: "Perdido",
      className: "border-red-500/40 bg-red-500/10 text-red-200 hover:bg-red-500/20",
    },
  ],
  qualified: [
    {
      value: "won",
      label: "Cerrado",
      className: "border-emerald-500/40 bg-emerald-500/10 text-emerald-200 hover:bg-emerald-500/20",
    },
    {
      value: "lost",
      label: "Perdido",
      className: "border-red-500/40 bg-red-500/10 text-red-200 hover:bg-red-500/20",
    },
  ],
};
const statusUpdateMessages: Record<string, { text: string; className: string }> = {
  ok: {
    text: "Estado actualizado correctamente.",
    className: "border-emerald-500/30 bg-emerald-500/10 text-emerald-300",
  },
  invalid_payload: {
    text: "No se pudo actualizar: datos invalidos.",
    className: "border-red-500/30 bg-red-500/10 text-red-300",
  },
  update_failed: {
    text: "No se pudo actualizar el estado en Supabase.",
    className: "border-red-500/30 bg-red-500/10 text-red-300",
  },
  unauthorized: {
    text: "Sesion expirada. Volve a iniciar sesion.",
    className: "border-red-500/30 bg-red-500/10 text-red-300",
  },
  config_error: {
    text: "Falta configuracion de servidor para actualizar estado.",
    className: "border-red-500/30 bg-red-500/10 text-red-300",
  },
};
const statusUpdateFeedback = statusUpdateMessages[statusUpdateResult];

const knownCountryItems = metrics.countries.filter((item) => item.code !== "ZZ");

const mapLeadsGeoJson = {
  type: "FeatureCollection",
  features: knownCountryItems
    .filter((item) => Number.isFinite(item.lon) && Number.isFinite(item.lat))
    .map((item) => ({
      type: "Feature",
      properties: {
        email: `${item.count} leads`,
        country: item.code,
      },
      geometry: {
        type: "Point",
        coordinates: [item.lon, item.lat],
      },
    })),
};
---

<Layout title="Metricas | MUGA" description="Panel simple de metricas de leads.">
  <Navigation>
    <Breadcrumb slot="mobile-breadcrumb" items={breadcrumbItems} />
  </Navigation>
  <div class="hidden lg:block">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <section class="section-space section-space-after-hero">
    <div class="page-container space-y-6">
      <div class="space-y-2">
        <span class="muga-badge muga-badge--sm">Interno</span>
        <h1 class="section-title">Metricas de leads</h1>
        <p class="section-lead">Panel rapido para monitorear volumen, prioridad y conversion con filtros simples.</p>
      </div>

      {!isAuthorized ? (
        <article class="mx-auto w-full max-w-lg border border-white/10 bg-muga-dark-800/35 p-6">
          <h2 class="text-lg font-semibold text-white">Acceso protegido</h2>
          <p class="mt-2 text-sm text-graylight">Ingresa la clave interna para abrir el panel de metricas.</p>
          <form method="POST" class="mt-5 space-y-3">
            <input type="hidden" name="action" value="login" />
            <label class="space-y-2">
              <span class="text-xs uppercase tracking-wider text-graylight">Clave</span>
              <input
                type="password"
                name="password"
                autocomplete="current-password"
                required
                class="w-full border border-white/15 bg-obscure px-3 py-2 text-sm text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
              />
            </label>
            {authError ? <p class="text-sm text-red-300">{authError}</p> : null}
              <button type="submit" class="inline-flex w-full items-center justify-center border border-accent/70 bg-accent px-4 py-2 text-sm font-semibold text-obscure hover:bg-accent/90">Entrar al panel</button>
          </form>
        </article>
      ) : loadError ? (
        <div class="border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300">{loadError}</div>
      ) : (
        <>
          {statusUpdateFeedback ? (
            <div class={`border px-4 py-3 text-sm ${statusUpdateFeedback.className}`}>{statusUpdateFeedback.text}</div>
          ) : null}

          <div class="flex justify-end">
            <form method="POST">
              <input type="hidden" name="action" value="logout" />
              <button type="submit" class="inline-flex items-center justify-center border border-white/20 px-4 py-2 text-sm font-semibold text-white hover:border-white/40">
                Cerrar sesion
              </button>
            </form>
          </div>

          <form method="GET" class="grid gap-4 border border-white/10 bg-muga-dark-800/35 p-4 sm:grid-cols-2 lg:grid-cols-6">
            <label class="space-y-2">
              <span class="text-xs uppercase tracking-wider text-graylight">Periodo</span>
              <select name="dias" class="w-full border border-white/15 bg-obscure px-3 py-2 text-sm text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                {diasOpciones.map((dias) => (
                  <option value={dias} selected={selectedDays === dias}>{dias} dias</option>
                ))}
              </select>
            </label>

            <label class="space-y-2">
              <span class="text-xs uppercase tracking-wider text-graylight">Estado</span>
              <select name="estado" class="w-full border border-white/15 bg-obscure px-3 py-2 text-sm text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                <option value="all" selected={selectedStatus === "all"}>Todos</option>
                {Object.entries(estadoEtiquetas).map(([value, label]) => (
                  <option value={value} selected={selectedStatus === value}>{label}</option>
                ))}
              </select>
            </label>

            <label class="space-y-2">
              <span class="text-xs uppercase tracking-wider text-graylight">Fuente</span>
              <select name="fuente" class="w-full border border-white/15 bg-obscure px-3 py-2 text-sm text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                <option value="all" selected={selectedSource === "all"}>Todas</option>
                {fuentesDisponibles.map((source) => (
                  <option value={source} selected={selectedSource === source}>{source}</option>
                ))}
              </select>
            </label>

            <label class="space-y-2">
              <span class="text-xs uppercase tracking-wider text-graylight">UTM source</span>
              <select name="utm_source" class="w-full border border-white/15 bg-obscure px-3 py-2 text-sm text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                <option value="all" selected={selectedUtmSource === "all"}>Todas</option>
                {utmSourcesDisponibles.map((utmSource) => (
                  <option value={utmSource} selected={selectedUtmSource === utmSource}>{utmSource}</option>
                ))}
              </select>
            </label>

            <label class="space-y-2">
              <span class="text-xs uppercase tracking-wider text-graylight">UTM campaign</span>
              <select name="utm_campaign" class="w-full border border-white/15 bg-obscure px-3 py-2 text-sm text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                <option value="all" selected={selectedUtmCampaign === "all"}>Todas</option>
                {utmCampaignsDisponibles.map((utmCampaign) => (
                  <option value={utmCampaign} selected={selectedUtmCampaign === utmCampaign}>{utmCampaign}</option>
                ))}
              </select>
            </label>

            <div class="flex flex-wrap items-end gap-2 lg:justify-end">
              <button type="submit" class="inline-flex w-full items-center justify-center border border-accent/70 bg-accent px-4 py-2 text-sm font-semibold text-obscure hover:bg-accent/90">Aplicar filtros</button>
              <a href={exportCsvHref} class="inline-flex w-full items-center justify-center border border-white/20 px-4 py-2 text-sm font-semibold text-white hover:border-white/40">Exportar CSV</a>
              <a href="/metricas" class="inline-flex w-full items-center justify-center border border-white/20 px-4 py-2 text-sm font-semibold text-white hover:border-white/40">Limpiar</a>
            </div>
          </form>

          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
            <article class="border border-white/10 bg-muga-dark-800/35 p-4">
              <p class="text-xs uppercase tracking-wider text-graylight">Leads filtrados</p>
              <p class="mt-2 text-3xl font-semibold text-white">{metrics.total}</p>
              <p class="mt-1 text-xs text-graylight">Total periodo: {metrics.enPeriodo}</p>
            </article>
            <article class="border border-white/10 bg-muga-dark-800/35 p-4">
              <p class="text-xs uppercase tracking-wider text-graylight">Embudo</p>
              <p class="mt-2 text-sm leading-7 text-white">Contacto: {funnel.contactRate}%</p>
              <p class="text-sm leading-7 text-white">Cualificacion: {funnel.qualificationRate}%</p>
              <p class="text-sm leading-7 text-white">Cierre: {funnel.winRate}%</p>
            </article>
            <article class="border border-white/10 bg-muga-dark-800/35 p-4">
              <p class="text-xs uppercase tracking-wider text-graylight">Prioridad alta</p>
              <p class="mt-2 text-3xl font-semibold text-white">{metrics.byTier.alto}</p>
              <p class="mt-1 text-xs text-graylight">Media: {metrics.byTier.calificado} · Normal: {metrics.byTier.nuevo}</p>
            </article>
            <article class="border border-white/10 bg-muga-dark-800/35 p-4">
              <p class="text-xs uppercase tracking-wider text-graylight">Estado nuevo</p>
              <p class="mt-2 text-3xl font-semibold text-white">{metrics.byStatus.new}</p>
              <p class="mt-1 text-xs text-graylight">Sin contacto inicial</p>
            </article>
          </div>

          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            <article class="border border-white/10 bg-muga-dark-800/35 p-4">
              <p class="text-xs uppercase tracking-wider text-graylight">Tiempo a primer contacto</p>
              <p class="mt-2 text-3xl font-semibold text-white">{formatHours(metrics.contactTiming.avgHoursToFirstContact)}</p>
              <p class="mt-1 text-xs text-graylight">Promedio en {metrics.contactTiming.measuredLeads} leads medidos</p>
            </article>
            <article class="border border-white/10 bg-muga-dark-800/35 p-4">
              <p class="text-xs uppercase tracking-wider text-graylight">Contactados en 24h</p>
              <p class="mt-2 text-3xl font-semibold text-white">{metrics.contactTiming.contactedWithin24h}%</p>
              <p class="mt-1 text-xs text-graylight">Sobre leads con primer contacto registrado</p>
            </article>
            <article class="border border-white/10 bg-muga-dark-800/35 p-4">
              <p class="text-xs uppercase tracking-wider text-graylight">Canal UTM principal</p>
              <p class="mt-2 text-2xl font-semibold text-white">
                {humanizeAttribution(metrics.attribution.utmSources[0]?.source || "sin_utm")}
              </p>
              <p class="mt-1 text-xs text-graylight">{metrics.attribution.utmSources[0]?.count || 0} leads</p>
            </article>
          </div>

          <div class="grid gap-4 lg:grid-cols-2">
            <article class="border border-white/10 bg-muga-dark-800/35 p-5">
              <h2 class="text-lg font-semibold text-white">Distribucion por estado</h2>
              <div class="mt-4 space-y-3">
                {estadoItems.map((item) => (
                  <div class="space-y-1">
                    <div class="flex items-center justify-between text-sm">
                      <p class="text-graylight">{item.label}</p>
                      <p class="font-semibold text-white">{item.value}</p>
                    </div>
                    <div class="h-2 w-full bg-white/10">
                      <div class="h-2 bg-accent" style={`width:${(item.value / maxEstado) * 100}%`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </article>

            <article class="border border-white/10 bg-muga-dark-800/35 p-5">
              <h2 class="text-lg font-semibold text-white">Distribucion por prioridad</h2>
              <div class="mt-4 space-y-3">
                {prioridadItems.map((item) => (
                  <div class="space-y-1">
                    <div class="flex items-center justify-between text-sm">
                      <p class="text-graylight">{item.label}</p>
                      <p class="font-semibold text-white">{item.value}</p>
                    </div>
                    <div class="h-2 w-full bg-white/10">
                      <div class="h-2 bg-white" style={`width:${(item.value / maxPrioridad) * 100}%`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </article>
          </div>

          <article class="border border-white/10 bg-muga-dark-800/35 p-5">
            <h2 class="text-lg font-semibold text-white">Tendencia diaria (ultimos dias)</h2>
            <div class="mt-4 grid grid-cols-7 gap-2 sm:grid-cols-10 lg:grid-cols-14">
              {tendencia.map((item) => (
                <div class="flex flex-col items-center gap-2">
                  <div class="flex h-32 w-full items-end bg-white/5 p-1">
                    <div class="w-full bg-accent/85" style={`height:${(item.total / maxTendencia) * 100}%`}></div>
                  </div>
                  <p class="text-[10px] text-graylight">{item.dia}</p>
                  <p class="text-xs font-semibold text-white">{item.total}</p>
                </div>
              ))}
            </div>
          </article>

          <article class="border border-white/10 bg-muga-dark-800/35 p-5">
            <h2 class="text-lg font-semibold text-white">Fuentes principales</h2>
            <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
              {metrics.sources.length ? (
                metrics.sources.map((item) => (
                  <div class="border border-white/10 bg-obscure/40 px-4 py-3">
                    <p class="text-xs uppercase tracking-wider text-graylight">{item.source}</p>
                    <p class="mt-1 text-2xl font-semibold text-white">{item.count}</p>
                  </div>
                ))
              ) : (
                <p class="text-sm text-graylight">Sin datos de fuente para los filtros actuales.</p>
              )}
            </div>
          </article>

          <article class="border border-white/10 bg-muga-dark-800/35 p-5">
            <h2 class="text-lg font-semibold text-white">Bandeja hoy · leads nuevos</h2>
            <p class="mt-2 text-sm text-graylight">Ordenada por antiguedad para priorizar seguimiento operativo.</p>
            <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
              <div class="border border-white/10 bg-obscure/40 px-4 py-3">
                <p class="text-xs uppercase tracking-wider text-graylight">Pendientes</p>
                <p class="mt-1 text-2xl font-semibold text-white">{bandejaResumen.total}</p>
              </div>
              <div class="border border-red-500/30 bg-red-500/10 px-4 py-3">
                <p class="text-xs uppercase tracking-wider text-red-300">Criticos >48h</p>
                <p class="mt-1 text-2xl font-semibold text-red-200">{bandejaResumen.critico}</p>
              </div>
              <div class="border border-amber-500/30 bg-amber-500/10 px-4 py-3">
                <p class="text-xs uppercase tracking-wider text-amber-300">Warning >24h</p>
                <p class="mt-1 text-2xl font-semibold text-amber-200">{bandejaResumen.warning}</p>
              </div>
              <div class="border border-emerald-500/30 bg-emerald-500/10 px-4 py-3">
                <p class="inline-flex items-center gap-1 text-xs uppercase tracking-wider text-emerald-300"><CircleCheck size={14} stroke-width={1.8} />En tiempo</p>
                <p class="mt-1 text-2xl font-semibold text-emerald-200">{bandejaResumen.normal}</p>
              </div>
            </div>
            {bandejaHoy.length ? (
              <div class="mt-4 overflow-x-auto">
                <table class="min-w-full text-sm">
                  <thead>
                    <tr class="border-b border-white/10 text-left text-xs uppercase tracking-wider text-graylight">
                      <th class="px-3 py-2">Antiguedad</th>
                      <th class="px-3 py-2">Prioridad</th>
                      <th class="px-3 py-2">Lead</th>
                      <th class="px-3 py-2">Proyecto</th>
                      <th class="px-3 py-2">Alta</th>
                      <th class="px-3 py-2">Accion</th>
                    </tr>
                  </thead>
                  <tbody>
                    {bandejaHoy.map((lead) => (
                      <tr class="border-b border-white/10 last:border-0">
                        <td class="px-3 py-2 font-semibold text-white">{formatHours(lead.ageHours)}</td>
                        <td class="px-3 py-2">
                          <span class={`inline-flex border px-2 py-1 text-xs font-semibold ${urgencyClass[lead.urgency]}`}>
                            {urgencyLabels[lead.urgency]}
                          </span>
                        </td>
                        <td class="px-3 py-2">
                          <p class="font-semibold text-white">{lead.name}</p>
                          <p class="text-xs text-graylight">{lead.email}</p>
                        </td>
                        <td class="px-3 py-2 text-graylight">{lead.project}</td>
                        <td class="px-3 py-2 text-graylight">{lead.createdAt}</td>
                        <td class="px-3 py-2">
                          <div class="flex flex-wrap gap-2">
                            {quickActionsByStatus.new.map((action) => (
                              <form method="POST" action="/api/leads/estado" class="js-status-form" data-next-status={action.value}>
                                <input type="hidden" name="lead_id" value={lead.id} />
                                <input type="hidden" name="status" value={action.value} />
                                <input type="hidden" name="return_to" value={returnToParam} />
                                <button type="submit" title={action.label} aria-label={action.label} class="inline-flex items-center justify-center border border-accent/40 bg-accent/10 px-2 py-1 text-accent hover:bg-accent/20">
                                  {action.value === "contacted" ? <UserCheck size={14} stroke-width={2} /> : null}
                                  {action.value === "qualified" ? <BadgeCheck size={14} stroke-width={2} /> : null}
                                  {action.value === "lost" ? <CircleX size={14} stroke-width={2} /> : null}
                                </button>
                              </form>
                            ))}
                          </div>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <p class="mt-4 text-sm text-graylight">No hay leads nuevos pendientes para este periodo/filtro.</p>
            )}
          </article>

          <article class="border border-white/10 bg-muga-dark-800/35 p-5">
            <h2 class="text-lg font-semibold text-white">Actualizacion rapida de estado</h2>
            <p class="mt-2 text-sm text-graylight">Ultimos leads segun filtros activos. Cambia estado y guarda sin salir del panel.</p>
            <form method="GET" class="mt-4 flex flex-wrap items-end gap-3">
              <input type="hidden" name="dias" value={String(selectedDays)} />
              <input type="hidden" name="estado" value={selectedStatus} />
              <input type="hidden" name="fuente" value={selectedSource} />
              <input type="hidden" name="utm_source" value={selectedUtmSource} />
              <input type="hidden" name="utm_campaign" value={selectedUtmCampaign} />
              <label class="space-y-2">
                <span class="text-xs uppercase tracking-wider text-graylight">Mostrar en tabla</span>
                <select name="quick_status" class="border border-white/15 bg-obscure px-2 py-1 text-xs text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                  <option value="new" selected={selectedQuickStatus === "new"}>Solo nuevos (recomendado)</option>
                  <option value="all" selected={selectedQuickStatus === "all"}>Todos los estados</option>
                </select>
              </label>
              <button type="submit" class="border border-white/20 px-3 py-1 text-xs font-semibold text-white hover:border-white/40">Aplicar</button>
            </form>
            {leadsRecientes.length ? (
              <div class="mt-4 overflow-x-auto">
                <table class="min-w-full text-sm">
                  <thead>
                    <tr class="border-b border-white/10 text-left text-xs uppercase tracking-wider text-graylight">
                      <th class="px-3 py-2">Fecha</th>
                      <th class="px-3 py-2">Lead</th>
                      <th class="px-3 py-2">Proyecto</th>
                      <th class="px-3 py-2">Estado</th>
                      <th class="px-3 py-2">Accion</th>
                      <th class="px-3 py-2">Rapido</th>
                    </tr>
                  </thead>
                  <tbody>
                    {leadsRecientes.map((lead) => (
                      <tr class="border-b border-white/10 last:border-0" data-lead-row-id={String(lead.id)}>
                        <td class="px-3 py-2 text-graylight">{lead.createdAt}</td>
                        <td class="px-3 py-2">
                          <p class="font-semibold text-white">{lead.name}</p>
                          <p class="text-xs text-graylight">{lead.email}</p>
                        </td>
                        <td class="px-3 py-2 text-graylight">{lead.project}</td>
                        <td class="px-3 py-2 text-graylight" data-lead-status-id={String(lead.id)}>{estadoEtiquetas[lead.status] || lead.status}</td>
                        <td class="px-3 py-2">
                          <form method="POST" action="/api/leads/estado" class="js-status-form flex items-center gap-2">
                            <input type="hidden" name="lead_id" value={lead.id} />
                            <input type="hidden" name="return_to" value={returnToParam} />
                            <select name="status" data-lead-select-id={String(lead.id)} class="border border-white/15 bg-obscure px-2 py-1 text-xs text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                              {Object.entries(estadoEtiquetas).map(([value, label]) => (
                                <option value={value} selected={lead.status === value}>{label}</option>
                              ))}
                            </select>
                            <button type="submit" class="border border-white/20 px-2 py-1 text-xs font-semibold text-white hover:border-white/40">Guardar</button>
                          </form>
                        </td>
                        <td class="px-3 py-2">
                          <div class="flex flex-wrap gap-2">
                            {(quickActionsByStatus[lead.status] || []).map((action) => (
                              <form method="POST" action="/api/leads/estado" class="js-status-form" data-next-status={action.value}>
                                <input type="hidden" name="lead_id" value={lead.id} />
                                <input type="hidden" name="status" value={action.value} />
                                <input type="hidden" name="return_to" value={returnToParam} />
                                <button type="submit" title={action.label} aria-label={action.label} class="inline-flex items-center justify-center border border-accent/40 bg-accent/10 px-2 py-1 text-accent hover:bg-accent/20">
                                  {action.value === "contacted" ? <UserCheck size={14} stroke-width={2} /> : null}
                                  {action.value === "qualified" ? <BadgeCheck size={14} stroke-width={2} /> : null}
                                  {action.value === "won" ? <CircleCheck size={14} stroke-width={2} /> : null}
                                  {action.value === "lost" ? <CircleX size={14} stroke-width={2} /> : null}
                                </button>
                              </form>
                            ))}
                          </div>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <p class="mt-4 text-sm text-graylight">Sin leads para actualizar con los filtros actuales.</p>
            )}
          </article>

          <div class="grid gap-4 lg:grid-cols-2">
            <article class="border border-white/10 bg-muga-dark-800/35 p-5">
              <h2 class="text-lg font-semibold text-white">Actividad por hora</h2>
              <p class="mt-2 text-sm text-graylight">Distribucion de envios segun hora local estimada del lead.</p>
              <div class="mt-4 grid grid-cols-12 gap-1">
                {metrics.activityByHour.map((item) => (
                  <div class="space-y-1 text-center">
                    <div class="mx-auto flex h-20 w-full max-w-[18px] items-end bg-white/5 p-[1px]">
                      <div class="w-full bg-accent/85" style={`height:${(item.total / maxActividadHora) * 100}%`}></div>
                    </div>
                    <p class="text-[10px] text-graylight">{String(item.hour).padStart(2, "0")}</p>
                  </div>
                ))}
              </div>
            </article>

            <article class="border border-white/10 bg-muga-dark-800/35 p-5">
              <h2 class="text-lg font-semibold text-white">Origen por pais (estimado)</h2>
              <p class="mt-2 text-sm text-graylight">Se estima por IP de Vercel y fallback por locale/timezone.</p>
              <div class="relative mt-4 overflow-hidden border border-white/10 bg-obscure/30">
                <div id="world-leads-map" class="h-[260px] w-full" data-leads-geojson={JSON.stringify(mapLeadsGeoJson)}></div>
                <div id="world-leads-map-tooltip" class="pointer-events-none absolute z-20 hidden border border-[#3A3A3A] bg-[#191717] px-2 py-1 text-xs text-white"></div>
                <div id="world-leads-map-loading" class="absolute inset-0 z-10 flex items-center justify-center bg-[#191717] text-xs uppercase tracking-[0.18em] text-graylight">Cargando mapa</div>
              </div>
              <div class="mt-3 space-y-2">
                {knownCountryItems.length ? (
                  knownCountryItems.map((item) => (
                    <div class="flex items-center justify-between text-sm">
                      <p class="text-graylight">{item.label} ({item.code})</p>
                      <p class="font-semibold text-white">{item.count}</p>
                    </div>
                  ))
                ) : (
                  <p class="text-sm text-graylight">Sin datos de pais identificable para los filtros actuales.</p>
                )}
              </div>
            </article>
          </div>

          <div class="grid gap-4 lg:grid-cols-2">
            <article class="border border-white/10 bg-muga-dark-800/35 p-5">
              <h2 class="text-lg font-semibold text-white">Canales UTM</h2>
              <div class="mt-4 grid gap-3 sm:grid-cols-2">
                {topUtmSourceItems.length ? (
                  topUtmSourceItems.map((item) => (
                    <div class="border border-white/10 bg-obscure/40 px-4 py-3">
                      <p class="text-xs uppercase tracking-wider text-graylight">{humanizeAttribution(item.source)}</p>
                      <p class="mt-1 text-2xl font-semibold text-white">{item.count}</p>
                    </div>
                  ))
                ) : (
                  <p class="text-sm text-graylight">Sin datos UTM source para los filtros actuales.</p>
                )}
              </div>
              {overflowUtmSourceItems.length ? (
                <details class="mt-4 border border-white/10 bg-obscure/20 p-3">
                  <summary class="cursor-pointer text-sm font-semibold text-white">Ver mas ({overflowUtmSourceItems.length})</summary>
                  <div class="mt-3 space-y-2">
                    {overflowUtmSourceItems.map((item) => (
                      <div class="flex items-center justify-between border-b border-white/10 pb-2 text-sm last:border-0 last:pb-0">
                        <p class="text-graylight">{humanizeAttribution(item.source)}</p>
                        <p class="font-semibold text-white">{item.count}</p>
                      </div>
                    ))}
                  </div>
                </details>
              ) : null}
            </article>

            <article class="border border-white/10 bg-muga-dark-800/35 p-5">
              <h2 class="text-lg font-semibold text-white">Campañas UTM</h2>
              <div class="mt-4 grid gap-3 sm:grid-cols-2">
                {topUtmCampaignItems.length ? (
                  topUtmCampaignItems.map((item) => (
                    <div class="border border-white/10 bg-obscure/40 px-4 py-3">
                      <p class="text-xs uppercase tracking-wider text-graylight">{humanizeAttribution(item.campaign)}</p>
                      <p class="mt-1 text-2xl font-semibold text-white">{item.count}</p>
                    </div>
                  ))
                ) : (
                  <p class="text-sm text-graylight">Sin datos UTM campaign para los filtros actuales.</p>
                )}
              </div>
              {overflowUtmCampaignItems.length ? (
                <details class="mt-4 border border-white/10 bg-obscure/20 p-3">
                  <summary class="cursor-pointer text-sm font-semibold text-white">Ver mas ({overflowUtmCampaignItems.length})</summary>
                  <div class="mt-3 space-y-2">
                    {overflowUtmCampaignItems.map((item) => (
                      <div class="flex items-center justify-between border-b border-white/10 pb-2 text-sm last:border-0 last:pb-0">
                        <p class="text-graylight">{humanizeAttribution(item.campaign)}</p>
                        <p class="font-semibold text-white">{item.count}</p>
                      </div>
                    ))}
                  </div>
                </details>
              ) : null}
            </article>
          </div>
        </>
      )}
    </div>
  </section>

  <script>
    const initWorldLeadsMap = async () => {
      const container = document.getElementById("world-leads-map");
      if (!container || container.dataset.bound === "true") return;
      container.dataset.bound = "true";

      const tooltip = document.getElementById("world-leads-map-tooltip");
      const loading = document.getElementById("world-leads-map-loading");
      const rawData = container.dataset.leadsGeojson || '{"type":"FeatureCollection","features":[]}';
      let leadsGeojson;

      try {
        leadsGeojson = JSON.parse(rawData);
      } catch {
        leadsGeojson = { type: "FeatureCollection", features: [] };
      }

      const { default: maplibregl } = await import("maplibre-gl");

      const themedStyleFrom = async (styleUrl) => {
        const response = await fetch(styleUrl);
        if (!response.ok) throw new Error("style_fetch_failed");
        const style = await response.json();
        const layers = Array.isArray(style.layers) ? style.layers : [];

        layers.forEach((layer) => {
          const id = String(layer.id || "").toLowerCase();

          if (layer.type === "background") {
            layer.paint = {
              ...(layer.paint || {}),
              "background-color": "#191717",
            };
            return;
          }

          if (layer.type === "symbol" || id.includes("label") || id.includes("road") || id.includes("poi") || id.includes("rail") || id.includes("airport") || id.includes("transit") || id.includes("path") || id.includes("highway")) {
            layer.layout = {
              ...(layer.layout || {}),
              visibility: "none",
            };
            return;
          }

          if (layer.type === "fill") {
            if (id.includes("water") || id.includes("ocean") || id.includes("sea")) {
              layer.paint = {
                ...(layer.paint || {}),
                "fill-color": "#191717",
                "fill-opacity": 1,
              };
              return;
            }

            if (id.includes("land") || id.includes("earth") || id.includes("park") || id.includes("landcover") || id.includes("landuse")) {
              layer.paint = {
                ...(layer.paint || {}),
                "fill-color": "#2D2E2E",
                "fill-opacity": 1,
              };
              return;
            }

            layer.paint = {
              ...(layer.paint || {}),
              "fill-opacity": 0,
            };
          }

          if (layer.type === "line") {
            if (id.includes("boundary") || id.includes("admin") || id.includes("country") || id.includes("coast")) {
              layer.paint = {
                ...(layer.paint || {}),
                "line-color": "#3A3A3A",
                "line-width": 1,
                "line-opacity": 1,
              };
              return;
            }

            if (id.includes("road") || id.includes("highway") || id.includes("street") || id.includes("path")) {
              layer.layout = {
                ...(layer.layout || {}),
                visibility: "none",
              };
            }
          }
        });

        style.layers = layers;
        return style;
      };

      let themedStyle;
      try {
        themedStyle = await themedStyleFrom("https://tiles.stadiamaps.com/styles/alidade_smooth_dark.json");
      } catch {
        themedStyle = await themedStyleFrom("https://demotiles.maplibre.org/style.json");
      }

      const map = new maplibregl.Map({
        container,
        style: themedStyle,
        center: [0, 20],
        zoom: 1.4,
        attributionControl: false,
      });

      const bindLoadEvents = () => {
        map.on("load", () => {
          if (loading) loading.classList.add("hidden");

          if (!map.getSource("leads-source")) {
            map.addSource("leads-source", {
              type: "geojson",
              data: leadsGeojson,
            });
          }

          if (!map.getLayer("leads-zones")) {
            map.addLayer({
              id: "leads-zones",
              type: "circle",
              source: "leads-source",
              paint: {
                "circle-radius": 18,
                "circle-color": "#FF5353",
                "circle-opacity": 0.18,
              },
            });
          }

          if (!map.getLayer("leads-circles")) {
            map.addLayer({
              id: "leads-circles",
              type: "circle",
              source: "leads-source",
              paint: {
                "circle-radius": 6,
                "circle-color": "#FF5353",
                "circle-opacity": 0.9,
              },
            });
          }

          map.on("mousemove", "leads-circles", (event) => {
          const feature = event.features?.[0];
          if (!feature || !tooltip) return;

          const email = String(feature.properties?.email || "sin email");
          const country = String(feature.properties?.country || "-");

          tooltip.innerHTML = `<div style=\"font-weight:600\">${email}</div><div style=\"opacity:0.85\">${country}</div>`;
          tooltip.style.left = `${event.point.x + 12}px`;
          tooltip.style.top = `${event.point.y + 12}px`;
          tooltip.classList.remove("hidden");
          map.getCanvas().style.cursor = "pointer";
        });

          map.on("mouseleave", "leads-circles", () => {
            if (tooltip) tooltip.classList.add("hidden");
            map.getCanvas().style.cursor = "";
          });
        });
      };

      bindLoadEvents();
    };

    initWorldLeadsMap();

    const forms = Array.from(document.querySelectorAll(".js-status-form"));
    if (forms.length) {
      const statusLabels: Record<string, string> = {
        new: "Nuevo",
        contacted: "Contactado",
        qualified: "Calificado",
        won: "Cerrado",
        lost: "Perdido",
      };

      forms.forEach((form) => {
        form.addEventListener("submit", async (event) => {
          if (!(form instanceof HTMLFormElement)) return;

          const formData = new FormData(form);
          const nextStatus = form.dataset.nextStatus || String(formData.get("status") || "");
          if (nextStatus === "lost") {
            const confirmed = window.confirm("Vas a marcar este lead como perdido. Continuar?");
            if (!confirmed) {
              event.preventDefault();
              return;
            }
          }

          event.preventDefault();

          const leadId = String(formData.get("lead_id") || "");
          const submitButton = form.querySelector('button[type="submit"]');
          if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;

          try {
            const response = await fetch(form.action, {
              method: "POST",
              body: formData,
              headers: {
                Accept: "application/json",
                "X-Requested-With": "fetch",
              },
            });

            const payload = await response.json().catch(() => ({}));
            if (!response.ok || !payload?.ok) {
              alert("No se pudo actualizar el estado.");
              return;
            }

            const status = String(payload.status || "");
            if (!status || !leadId) return;
            const statusLabel =
              status in statusLabels
                ? statusLabels[status as keyof typeof statusLabels]
                : status;

            document.querySelectorAll(`[data-lead-status-id="${leadId}"]`).forEach((node) => {
              if (node instanceof HTMLElement) node.textContent = statusLabel;
            });

            document.querySelectorAll(`[data-lead-select-id="${leadId}"]`).forEach((node) => {
              if (node instanceof HTMLSelectElement) node.value = status;
            });

            if (status !== "new") {
              document.querySelectorAll(`[data-lead-row-id="${leadId}"]`).forEach((row) => {
                if (row instanceof HTMLElement) row.remove();
              });
            }
          } catch {
            alert("No se pudo actualizar el estado.");
          } finally {
            if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
          }
        });
      });
    }
  </script>
</Layout>
