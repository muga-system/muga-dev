---
import Layout from "../layouts/layout.astro";
import Navigation from "../components/ui/Navigation/Navigation.astro";
import Breadcrumb from "../components/ui/Breadcrumb/Breadcrumb.astro";
import type { BreadcrumbItem } from "../types";
import {
  METRICAS_SESSION_COOKIE,
  createMetricasSessionToken,
  isMetricasSessionValid,
} from "../lib/metricas-auth.js";

const breadcrumbItems: BreadcrumbItem[] = [
  {
    label: "Metricas",
    href: "/metricas",
    active: true,
  },
];

const supabaseUrl = import.meta.env.SUPABASE_URL;
const supabaseServiceRoleKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;
const leadsTable = import.meta.env.SUPABASE_LEADS_TABLE || "leads";
const panelPassword = process.env.METRICAS_PANEL_PASSWORD || import.meta.env.METRICAS_PANEL_PASSWORD;
const sessionSalt = process.env.METRICAS_SESSION_SALT || import.meta.env.METRICAS_SESSION_SALT || "muga-metricas-v1";

const method = Astro.request.method.toUpperCase();
let authError = panelPassword ? "" : "Falta configurar METRICAS_PANEL_PASSWORD en el servidor.";

if (method === "POST") {
  const formData = await Astro.request.formData();
  const action = String(formData.get("action") || "login");

  if (action === "logout") {
    Astro.cookies.delete(METRICAS_SESSION_COOKIE, { path: "/" });
    return Astro.redirect("/metricas");
  }

  const submittedPassword = String(formData.get("password") || "");

  if (!panelPassword) {
    authError = "Falta configurar METRICAS_PANEL_PASSWORD en el servidor.";
  } else if (submittedPassword && submittedPassword === panelPassword) {
    const sessionToken = createMetricasSessionToken(panelPassword, sessionSalt);
    Astro.cookies.set(METRICAS_SESSION_COOKIE, sessionToken, {
      path: "/",
      httpOnly: true,
      sameSite: "strict",
      secure: Astro.url.protocol === "https:",
      maxAge: 60 * 60 * 12,
    });
    return Astro.redirect("/metricas");
  } else {
    authError = "Clave invalida.";
  }
}

const sessionCookieValue = Astro.cookies.get(METRICAS_SESSION_COOKIE)?.value || "";
const isAuthorized = isMetricasSessionValid({
  cookieValue: sessionCookieValue,
  panelPassword,
  sessionSalt,
});

const parsePositiveInt = (value: string | null, fallback: number) => {
  const parsed = Number(value);
  if (!Number.isFinite(parsed) || parsed <= 0) return fallback;
  return Math.floor(parsed);
};

const estadoEtiquetas: Record<string, string> = {
  new: "Nuevo",
  contacted: "Contactado",
  qualified: "Calificado",
  won: "Cerrado",
  lost: "Perdido",
};

const getLeadTier = (lead: { lead_stage?: string; budget?: string }) => {
  const stage = String(lead?.lead_stage || "").toLowerCase();
  const budget = String(lead?.budget || "").toLowerCase();
  if (stage === "high-intent" || budget === "premium") return "alto";
  if (stage === "qualified" || budget === "business") return "calificado";
  return "nuevo";
};

const formatDay = (date: Date) =>
  date.toLocaleDateString("es-AR", {
    day: "2-digit",
    month: "2-digit",
  });

const diasOpciones = [1, 7, 30, 90];

const selectedDays = parsePositiveInt(Astro.url.searchParams.get("dias"), 30);
const selectedStatus = (Astro.url.searchParams.get("estado") || "all").toLowerCase();
const selectedSource = (Astro.url.searchParams.get("fuente") || "all").toLowerCase();
const exportCsvParams = new URLSearchParams({
  dias: String(selectedDays),
  estado: selectedStatus,
  fuente: selectedSource,
});
const exportCsvHref = `/api/leads/export.csv?${exportCsvParams.toString()}`;

let loadError = "";

const metrics = {
  total: 0,
  enPeriodo: 0,
  byStatus: {
    new: 0,
    contacted: 0,
    qualified: 0,
    won: 0,
    lost: 0,
  },
  byTier: {
    alto: 0,
    calificado: 0,
    nuevo: 0,
  },
  sources: [] as Array<{ source: string; count: number }>,
};

const funnel = {
  contactRate: 0,
  qualificationRate: 0,
  winRate: 0,
};

const tendencia: Array<{ dia: string; total: number }> = [];
const fuentesDisponibles: string[] = [];

if (!isAuthorized) {
  loadError = "";
} else if (!supabaseUrl || !supabaseServiceRoleKey) {
  loadError = "Faltan variables de servidor para cargar metricas.";
} else {
  const cutoffIso = new Date(Date.now() - selectedDays * 24 * 60 * 60 * 1000).toISOString();

  const query = new URL(`${supabaseUrl}/rest/v1/${leadsTable}`);
  query.searchParams.set("select", "id,created_at,status,lead_stage,budget,source");
  query.searchParams.set("created_at", `gte.${cutoffIso}`);
  query.searchParams.set("order", "created_at.desc");
  query.searchParams.set("limit", "5000");

  const response = await fetch(query.toString(), {
    headers: {
      apikey: supabaseServiceRoleKey,
      Authorization: `Bearer ${supabaseServiceRoleKey}`,
    },
  });

  if (!response.ok) {
    loadError = `No se pudieron cargar metricas (${response.status}).`;
  } else {
    const rows = (await response.json()) as Array<{
      created_at?: string;
      status?: string;
      lead_stage?: string;
      budget?: string;
      source?: string;
    }>;

    const allSourceCounter = new Map<string, number>();

    metrics.enPeriodo = rows.length;

    rows.forEach((lead) => {
      const source = String(lead.source || "desconocido").toLowerCase();
      allSourceCounter.set(source, (allSourceCounter.get(source) || 0) + 1);
    });

    fuentesDisponibles.push(...[...allSourceCounter.keys()].sort());

    const filteredRows = rows.filter((lead) => {
      const status = String(lead.status || "new").toLowerCase();
      const source = String(lead.source || "desconocido").toLowerCase();

      if (selectedStatus !== "all" && status !== selectedStatus) return false;
      if (selectedSource !== "all" && source !== selectedSource) return false;
      return true;
    });

    metrics.total = filteredRows.length;
    const filteredSourceCounter = new Map<string, number>();
    const filteredDaily = new Map<string, number>();

    filteredRows.forEach((lead) => {
      const status = String(lead.status || "new").toLowerCase();
      const source = String(lead.source || "desconocido").toLowerCase();

      if (status in metrics.byStatus) {
        metrics.byStatus[status as keyof typeof metrics.byStatus] += 1;
      }

      const tier = getLeadTier(lead);
      metrics.byTier[tier as keyof typeof metrics.byTier] += 1;

      filteredSourceCounter.set(source, (filteredSourceCounter.get(source) || 0) + 1);

      const createdDate = new Date(String(lead.created_at || ""));
      if (!Number.isNaN(createdDate.getTime())) {
        const key = createdDate.toISOString().slice(0, 10);
        filteredDaily.set(key, (filteredDaily.get(key) || 0) + 1);
      }
    });

    metrics.sources = [...filteredSourceCounter.entries()]
      .map(([source, count]) => ({ source, count }))
      .sort((a, b) => b.count - a.count)
      .slice(0, 8);

    const contactedOrMore =
      metrics.byStatus.contacted +
      metrics.byStatus.qualified +
      metrics.byStatus.won +
      metrics.byStatus.lost;
    const qualifiedOrMore = metrics.byStatus.qualified + metrics.byStatus.won;

    funnel.contactRate = metrics.total
      ? Number(((contactedOrMore / metrics.total) * 100).toFixed(1))
      : 0;
    funnel.qualificationRate = metrics.total
      ? Number(((qualifiedOrMore / metrics.total) * 100).toFixed(1))
      : 0;
    funnel.winRate = metrics.total
      ? Number(((metrics.byStatus.won / metrics.total) * 100).toFixed(1))
      : 0;

    const maxBars = Math.min(selectedDays, 14);
    const dayMs = 24 * 60 * 60 * 1000;
    for (let i = maxBars - 1; i >= 0; i--) {
      const day = new Date(Date.now() - i * dayMs);
      const isoKey = day.toISOString().slice(0, 10);
      tendencia.push({
        dia: formatDay(day),
        total: filteredDaily.get(isoKey) || 0,
      });
    }
  }
}

const estadoItems = [
  { key: "new", label: "Nuevo", value: metrics.byStatus.new },
  { key: "contacted", label: "Contactado", value: metrics.byStatus.contacted },
  { key: "qualified", label: "Calificado", value: metrics.byStatus.qualified },
  { key: "won", label: "Cerrado", value: metrics.byStatus.won },
  { key: "lost", label: "Perdido", value: metrics.byStatus.lost },
];

const prioridadItems = [
  { key: "alto", label: "Alta", value: metrics.byTier.alto },
  { key: "calificado", label: "Media", value: metrics.byTier.calificado },
  { key: "nuevo", label: "Normal", value: metrics.byTier.nuevo },
];

const maxEstado = Math.max(1, ...estadoItems.map((item) => item.value));
const maxPrioridad = Math.max(1, ...prioridadItems.map((item) => item.value));
const maxTendencia = Math.max(1, ...tendencia.map((item) => item.total));
---

<Layout title="Metricas | MUGA" description="Panel simple de metricas de leads.">
  <Navigation>
    <Breadcrumb slot="mobile-breadcrumb" items={breadcrumbItems} />
  </Navigation>
  <div class="hidden lg:block">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <section class="section-space section-space-after-hero">
    <div class="page-container space-y-6">
      <div class="space-y-2">
        <span class="muga-badge muga-badge--sm">Interno</span>
        <h1 class="section-title">Metricas de leads</h1>
        <p class="section-lead">Panel rapido para monitorear volumen, prioridad y conversion con filtros simples.</p>
      </div>

      {!isAuthorized ? (
        <article class="mx-auto w-full max-w-lg border border-white/10 bg-muga-dark-800/35 p-6">
          <h2 class="text-lg font-semibold text-white">Acceso protegido</h2>
          <p class="mt-2 text-sm text-graylight">Ingresa la clave interna para abrir el panel de metricas.</p>
          <form method="POST" class="mt-5 space-y-3">
            <input type="hidden" name="action" value="login" />
            <label class="space-y-2">
              <span class="text-xs uppercase tracking-wider text-graylight">Clave</span>
              <input
                type="password"
                name="password"
                autocomplete="current-password"
                required
                class="w-full border border-white/15 bg-obscure px-3 py-2 text-sm text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
              />
            </label>
            {authError ? <p class="text-sm text-red-300">{authError}</p> : null}
            <button type="submit" class="inline-flex w-full items-center justify-center border border-accent/70 bg-accent px-4 py-2 text-sm font-semibold text-obscure hover:bg-accent/90">
              Entrar al panel
            </button>
          </form>
        </article>
      ) : loadError ? (
        <div class="border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300">{loadError}</div>
      ) : (
        <>
          <div class="flex justify-end">
            <form method="POST">
              <input type="hidden" name="action" value="logout" />
              <button type="submit" class="inline-flex items-center justify-center border border-white/20 px-4 py-2 text-sm font-semibold text-white hover:border-white/40">
                Cerrar sesion
              </button>
            </form>
          </div>

          <form method="GET" class="grid gap-4 border border-white/10 bg-muga-dark-800/35 p-4 sm:grid-cols-2 lg:grid-cols-4">
            <label class="space-y-2">
              <span class="text-xs uppercase tracking-wider text-graylight">Periodo</span>
              <select name="dias" class="w-full border border-white/15 bg-obscure px-3 py-2 text-sm text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                {diasOpciones.map((dias) => (
                  <option value={dias} selected={selectedDays === dias}>{dias} dias</option>
                ))}
              </select>
            </label>

            <label class="space-y-2">
              <span class="text-xs uppercase tracking-wider text-graylight">Estado</span>
              <select name="estado" class="w-full border border-white/15 bg-obscure px-3 py-2 text-sm text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                <option value="all" selected={selectedStatus === "all"}>Todos</option>
                {Object.entries(estadoEtiquetas).map(([value, label]) => (
                  <option value={value} selected={selectedStatus === value}>{label}</option>
                ))}
              </select>
            </label>

            <label class="space-y-2">
              <span class="text-xs uppercase tracking-wider text-graylight">Fuente</span>
              <select name="fuente" class="w-full border border-white/15 bg-obscure px-3 py-2 text-sm text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                <option value="all" selected={selectedSource === "all"}>Todas</option>
                {fuentesDisponibles.map((source) => (
                  <option value={source} selected={selectedSource === source}>{source}</option>
                ))}
              </select>
            </label>

            <div class="flex flex-wrap items-end gap-2 lg:justify-end">
              <button type="submit" class="inline-flex w-full items-center justify-center border border-accent/70 bg-accent px-4 py-2 text-sm font-semibold text-obscure hover:bg-accent/90">Aplicar filtros</button>
              <a href={exportCsvHref} class="inline-flex w-full items-center justify-center border border-white/20 px-4 py-2 text-sm font-semibold text-white hover:border-white/40">Exportar CSV</a>
              <a href="/metricas" class="inline-flex w-full items-center justify-center border border-white/20 px-4 py-2 text-sm font-semibold text-white hover:border-white/40">Limpiar</a>
            </div>
          </form>

          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
            <article class="border border-white/10 bg-muga-dark-800/35 p-4">
              <p class="text-xs uppercase tracking-wider text-graylight">Leads filtrados</p>
              <p class="mt-2 text-3xl font-semibold text-white">{metrics.total}</p>
              <p class="mt-1 text-xs text-graylight">Total periodo: {metrics.enPeriodo}</p>
            </article>
            <article class="border border-white/10 bg-muga-dark-800/35 p-4">
              <p class="text-xs uppercase tracking-wider text-graylight">Embudo</p>
              <p class="mt-2 text-sm leading-7 text-white">Contacto: {funnel.contactRate}%</p>
              <p class="text-sm leading-7 text-white">Cualificacion: {funnel.qualificationRate}%</p>
              <p class="text-sm leading-7 text-white">Cierre: {funnel.winRate}%</p>
            </article>
            <article class="border border-white/10 bg-muga-dark-800/35 p-4">
              <p class="text-xs uppercase tracking-wider text-graylight">Prioridad alta</p>
              <p class="mt-2 text-3xl font-semibold text-white">{metrics.byTier.alto}</p>
              <p class="mt-1 text-xs text-graylight">Media: {metrics.byTier.calificado} · Normal: {metrics.byTier.nuevo}</p>
            </article>
            <article class="border border-white/10 bg-muga-dark-800/35 p-4">
              <p class="text-xs uppercase tracking-wider text-graylight">Estado nuevo</p>
              <p class="mt-2 text-3xl font-semibold text-white">{metrics.byStatus.new}</p>
              <p class="mt-1 text-xs text-graylight">Sin contacto inicial</p>
            </article>
          </div>

          <div class="grid gap-4 lg:grid-cols-2">
            <article class="border border-white/10 bg-muga-dark-800/35 p-5">
              <h2 class="text-lg font-semibold text-white">Distribucion por estado</h2>
              <div class="mt-4 space-y-3">
                {estadoItems.map((item) => (
                  <div class="space-y-1">
                    <div class="flex items-center justify-between text-sm">
                      <p class="text-graylight">{item.label}</p>
                      <p class="font-semibold text-white">{item.value}</p>
                    </div>
                    <div class="h-2 w-full bg-white/10">
                      <div class="h-2 bg-accent" style={`width:${(item.value / maxEstado) * 100}%`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </article>

            <article class="border border-white/10 bg-muga-dark-800/35 p-5">
              <h2 class="text-lg font-semibold text-white">Distribucion por prioridad</h2>
              <div class="mt-4 space-y-3">
                {prioridadItems.map((item) => (
                  <div class="space-y-1">
                    <div class="flex items-center justify-between text-sm">
                      <p class="text-graylight">{item.label}</p>
                      <p class="font-semibold text-white">{item.value}</p>
                    </div>
                    <div class="h-2 w-full bg-white/10">
                      <div class="h-2 bg-white" style={`width:${(item.value / maxPrioridad) * 100}%`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </article>
          </div>

          <article class="border border-white/10 bg-muga-dark-800/35 p-5">
            <h2 class="text-lg font-semibold text-white">Tendencia diaria (ultimos dias)</h2>
            <div class="mt-4 grid grid-cols-7 gap-2 sm:grid-cols-10 lg:grid-cols-14">
              {tendencia.map((item) => (
                <div class="flex flex-col items-center gap-2">
                  <div class="flex h-32 w-full items-end bg-white/5 p-1">
                    <div class="w-full bg-accent/85" style={`height:${(item.total / maxTendencia) * 100}%`}></div>
                  </div>
                  <p class="text-[10px] text-graylight">{item.dia}</p>
                  <p class="text-xs font-semibold text-white">{item.total}</p>
                </div>
              ))}
            </div>
          </article>

          <article class="border border-white/10 bg-muga-dark-800/35 p-5">
            <h2 class="text-lg font-semibold text-white">Fuentes principales</h2>
            <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
              {metrics.sources.length ? (
                metrics.sources.map((item) => (
                  <div class="border border-white/10 bg-obscure/40 px-4 py-3">
                    <p class="text-xs uppercase tracking-wider text-graylight">{item.source}</p>
                    <p class="mt-1 text-2xl font-semibold text-white">{item.count}</p>
                  </div>
                ))
              ) : (
                <p class="text-sm text-graylight">Sin datos de fuente para los filtros actuales.</p>
              )}
            </div>
          </article>
        </>
      )}
    </div>
  </section>
</Layout>
