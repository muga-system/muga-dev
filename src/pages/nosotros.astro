---
import Layout from "../layouts/layout.astro";
import Navigation from "../components/ui/Navigation/Navigation.astro";
import Breadcrumb from "../components/ui/Breadcrumb/Breadcrumb.astro";
import PageHeroSection from "../components/HeroSection/PageHeroSection.astro";
import type { BreadcrumbItem } from "../types";

const breadcrumbItems: BreadcrumbItem[] = [
  {
    label: "Nosotros",
    href: "/nosotros",
    active: true,
  },
];
---

<Layout title="Nosotros | MUGA" description="Arquitectura web como sistema, con foco en conversion.">
  <Navigation>
    <Breadcrumb slot="mobile-breadcrumb" items={breadcrumbItems} />
  </Navigation>
  <div class="hidden lg:block">
    <Breadcrumb items={breadcrumbItems} />
  </div>
  <PageHeroSection
    title="Nosotros"
    description="Arquitectura web como sistema, con criterio técnico y foco en conversión."
    textAlign="left"
    showBadge={true}
    badgeText="MUGA"
  />

  <section class="relative px-6 lg:px-8 py-24">
    <div class="mx-auto max-w-7xl space-y-16">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <div class="lg:col-span-7">
          <div class="mb-4">
            <span class="muga-badge muga-badge--sm">Nosotros</span>
          </div>
          <h2 class="section-title mb-5 max-w-2xl">
            Estructura web con criterio técnico y foco en conversión.
          </h2>
          <p class="section-lead">
            No vendemos páginas sueltas. Construimos sistemas web mantenibles, rápidos y medibles para crecer sin rehacer la base.
          </p>
        </div>

        <aside class="lg:col-span-5 border border-white/10 bg-muga-dark-800/40 p-6">
          <div class="mb-3">
            <span class="muga-badge muga-badge--sm">Cómo lo hacemos</span>
          </div>
          <p class="text-white text-2xl font-light mb-4">Base tecnica estable</p>
          <ul class="space-y-2 text-sm text-muga-neutral">
            <li>Arquitectura modular desde el inicio.</li>
            <li>Métricas definidas antes de desarrollar.</li>
            <li>Entrega con documentación y continuidad técnica.</li>
          </ul>
        </aside>
      </div>

      <div>
        <div class="mb-6">
          <div class="mb-3">
            <span class="muga-badge muga-badge--sm">Qué garantizamos</span>
          </div>
          <p class="section-lead max-w-3xl">
            Definimos criterios técnicos desde el inicio y dejamos claro qué se mide, qué se entrega y qué sostiene la estructura.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <article class="border border-white/10 bg-muga-dark-800/35 p-6">
            <h3 class="text-white text-xl font-medium mb-4">Velocidad</h3>
            <ul class="space-y-2 text-muga-neutral text-sm">
              <li>LCP &lt;= 2.5s</li>
              <li>CLS &lt;= 0.1</li>
              <li>INP &lt;= 200ms</li>
            </ul>
          </article>

          <article class="border border-white/10 bg-muga-dark-800/35 p-6">
            <h3 class="text-white text-xl font-medium mb-4">Accesibilidad</h3>
            <ul class="space-y-2 text-muga-neutral text-sm">
              <li>WCAG AA (&gt;= 90)</li>
              <li>SEO (&gt;= 95%)</li>
              <li>Indexación técnica correcta</li>
            </ul>
          </article>

          <article class="border border-white/10 bg-muga-dark-800/35 p-6">
            <h3 class="text-white text-xl font-medium mb-4">Confiabilidad</h3>
            <ul class="space-y-2 text-muga-neutral text-sm">
              <li>HTTPS seguro</li>
              <li>Headers de seguridad</li>
              <li>Disponibilidad &gt;= 99.9%</li>
            </ul>
          </article>
        </div>
      </div>

      <div class="border border-white/10 bg-muga-dark-800/25 p-8">
        <div class="mb-4">
          <span class="muga-badge muga-badge--sm">Criterio de trabajo</span>
        </div>
        <p class="text-white text-2xl font-light leading-tight mb-6">
          Ordenamos antes de construir.
        </p>
        <p class="section-lead max-w-3xl">
          Trabajamos con decisiones explícitas, medición real y una base técnica lista para crecer sin desorden.
        </p>
      </div>
    </div>
  </section>
</Layout>
